    ],
    "scripts": {
        "build": "pnpm prebuild:tokens && pnpm prebuild:scan && pnpm prebuild:component-index && pnpm prebuild:exports && vite build && pnpm postbuild:exports && npm run build:preflight",
        "prebuild:scan": "tsx scripts/prebuild-scan.ts",
        "prebuild:tokens": "tsx scripts/generate-styles-tokens.ts",
        "prebuild:component-index": "tsx scripts/generate-component-index.ts",
        "prebuild:exports": "tsx scripts/generate-exports.ts",
        "postbuild:exports": "tsx scripts/generate-exports.ts --verify",
        "build:preflight": "tailwindcss -i src/preflight.css -o dist/preflight.css",
        "prepack": "npm run build",
        "dev": "vite build --watch",
        "clean": "rm -rf dist",
        "check:exports": "tsx scripts/check-exports.ts",
        "audit:fallback": "tsx scripts/audit-brutal-fallback.ts",
        "audit:fallback:check": "tsx scripts/audit-brutal-fallback.ts --check-baseline",
        "audit:fallback:update": "tsx scripts/audit-brutal-fallback.ts --update-baseline",
        "typecheck": "pnpm prebuild:scan && pnpm prebuild:component-index && vue-tsc --noEmit",
        "lint": "pnpm prebuild:scan && pnpm prebuild:component-index && eslint src",
        "test": "vitest run",
        "test:browser": "vitest run --config vitest.browser.config.ts",
        "test:ssr": "vitest run --config vitest.ssr.config.ts",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "bench": "vitest bench",
        "bench:json": "vitest bench --reporter=json",
        "test:package": "node scripts/smoke-package.mjs",
        "size": "size-limit",
        "size:why": "size-limit --why",
        "visual:dev": "vite --config visual/vite.config.ts --host 127.0.0.1",
        "test:visual": "vite build --config visual/vite.config.ts && playwright test --config playwright.config.ts",
        "test:visual:update": "vite build --config visual/vite.config.ts && playwright test --config playwright.config.ts --update-snapshots",
        "docs:api": "typedoc",
        "docs:api:full": "npx tsx scripts/generate-api-docs.ts",
        "docs:api:vue": "npx tsx scripts/generate-api-docs.ts --skip-typedoc"
    },
    "size-limit": [
        {
            "name": "main entry (ESM, full)",
            "path": "dist/index.js",
            "limit": "155 KB",
            "import": "*"
        },
        {
            "name": "Button (tree-shaken)",
            "path": "dist/index.js",
            "limit": "20 KB",
            "import": "{ Button }"
        },
        {
            "name": "CSS",
            "path": "dist/styles.css",
            "limit": "20 KB"
        }
    ],
