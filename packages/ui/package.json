{
    "name": "brutx-ui-vue",
    "version": "0.7.6",
    "description": "A Neo-Brutalism styled Vue 3 UI component library",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./calendar": {
            "types": "./dist/calendar.d.ts",
            "import": "./dist/calendar.js",
            "require": "./dist/calendar.cjs"
        },
        "./submit-button": {
            "types": "./dist/submit-button.d.ts",
            "import": "./dist/submit-button.js",
            "require": "./dist/submit-button.cjs"
        },
        "./hooks": {
            "types": "./dist/hooks.d.ts",
            "import": "./dist/hooks.js",
            "require": "./dist/hooks.cjs"
        },
        "./brutalism-plugin": {
            "types": "./dist/brutalism-plugin.d.ts",
            "import": "./dist/brutalism-plugin.js",
            "require": "./dist/brutalism-plugin.cjs"
        },
        "./locales": {
            "types": "./dist/locales.d.ts",
            "import": "./dist/locales.js",
            "require": "./dist/locales.cjs"
        },
        "./styles.css": "./dist/styles.css"
    },
    "files": [
        "dist"
    ],
    "sideEffects": [
        "**/*.css",
        "*.css"
    ],
    "scripts": {
        "build": "vite build",
        "prepack": "vite build",
        "dev": "vite build --watch",
        "clean": "rimraf dist",
        "typecheck": "vue-tsc --noEmit",
        "lint": "eslint src",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "visual:dev": "vite --config visual/vite.config.ts --host 127.0.0.1",
        "test:visual": "vite build --config visual/vite.config.ts && playwright test --config playwright.config.ts",
        "test:visual:update": "vite build --config visual/vite.config.ts && playwright test --config playwright.config.ts --update-snapshots"
    },
    "peerDependencies": {
        "@lucide/vue": ">=1.0.0",
        "prismjs": ">=1.29.0",
        "tailwindcss": ">=4.0.0",
        "vee-validate": ">=4.0.0",
        "vue": ">=3.5.0",
        "zod": ">=3.0.0"
    },
    "peerDependenciesMeta": {
        "prismjs": {
            "optional": true
        },
        "zod": {
            "optional": true
        },
        "vee-validate": {
            "optional": true
        }
    },
    "dependencies": {
        "@tanstack/vue-virtual": "^3.13.30",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.0",
        "embla-carousel-vue": "^8.6.0",
        "reka-ui": "^2.9.9",
        "tailwind-merge": "^3.6.0",
        "v-calendar": "^3.1.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/postcss": "^4.3.0",
        "@tailwindcss/vite": "^4.3.0",
        "@types/node": "^25.9.1",
        "@types/prismjs": "^1.26.6",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vitest/coverage-v8": "^4.1.8",
        "@vue/test-utils": "^2.4.0",
        "eslint": "^10.4.1",
        "eslint-plugin-vue": "^10.9.2",
        "globals": "^17.6.0",
        "happy-dom": "^20.9.0",
        "jsdom": "^29.1.1",
        "postcss": "^8.5.15",
        "rimraf": "^6.1.3",
        "tailwindcss": "^4.3.0",
        "tailwindcss-animate": "^1.0.7",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "vite": "^8.0.16",
        "vite-plugin-dts": "^5.0.2",
        "vitest": "^4.1.8",
        "vue": "^3.5.0",
        "vue-tsc": "^3.3.3"
    },
    "keywords": [
        "vue",
        "vue3",
        "ui",
        "ui-library",
        "ui-components",
        "components",
        "brutalism",
        "neo-brutalism",
        "brutalist",
        "design-system",
        "tailwindcss",
        "tailwind",
        "reka-ui",
        "typescript",
        "frontend",
        "accessible",
        "dark-mode"
    ],
    "author": "lidaixingchen",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/lidaixingchen/brutxui-vue3"
    },
    "publishConfig": {
        "access": "public"
    },
    "bugs": {
        "url": "https://github.com/lidaixingchen/brutxui-vue3/issues"
    },
    "homepage": "https://lidaixingchen.github.io/brutxui-vue3/"
}
