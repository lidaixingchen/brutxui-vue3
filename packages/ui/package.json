{
    "name": "brutx-ui-vue",
    "version": "0.9.0",
    "description": "A Neo-Brutalism styled Vue 3 UI component library",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./calendar": {
            "types": "./dist/calendar.d.ts",
            "import": "./dist/calendar.js",
            "require": "./dist/calendar.cjs"
        },
        "./carousel": {
            "types": "./dist/carousel.d.ts",
            "import": "./dist/carousel.js",
            "require": "./dist/carousel.cjs"
        },
        "./code-block": {
            "types": "./dist/code-block.d.ts",
            "import": "./dist/code-block.js",
            "require": "./dist/code-block.cjs"
        },
        "./hooks": {
            "types": "./dist/hooks.d.ts",
            "import": "./dist/hooks.js",
            "require": "./dist/hooks.cjs"
        },
        "./brutalism-plugin": {
            "types": "./dist/brutalism-plugin.d.ts",
            "import": "./dist/brutalism-plugin.js",
            "require": "./dist/brutalism-plugin.cjs"
        },
        "./devtools-plugin": {
            "types": "./dist/devtools-plugin.d.ts",
            "import": "./dist/devtools-plugin.js",
            "require": "./dist/devtools-plugin.cjs"
        },
        "./locales": {
            "types": "./dist/locales.d.ts",
            "import": "./dist/locales.js",
            "require": "./dist/locales.cjs"
        },
        "./button": {
            "types": "./dist/button.d.ts",
            "import": "./dist/button.js",
            "require": "./dist/button.cjs"
        },
        "./input": {
            "types": "./dist/input.d.ts",
            "import": "./dist/input.js",
            "require": "./dist/input.cjs"
        },
        "./dialog": {
            "types": "./dist/dialog.d.ts",
            "import": "./dist/dialog.js",
            "require": "./dist/dialog.cjs"
        },
        "./toast": {
            "types": "./dist/toast.d.ts",
            "import": "./dist/toast.js",
            "require": "./dist/toast.cjs"
        },
        "./form": {
            "types": "./dist/form.d.ts",
            "import": "./dist/form.js",
            "require": "./dist/form.cjs"
        },
        "./select": {
            "types": "./dist/select.d.ts",
            "import": "./dist/select.js",
            "require": "./dist/select.cjs"
        },
        "./dropdown-menu": {
            "types": "./dist/dropdown-menu.d.ts",
            "import": "./dist/dropdown-menu.js",
            "require": "./dist/dropdown-menu.cjs"
        },
        "./table": {
            "types": "./dist/table.d.ts",
            "import": "./dist/table.js",
            "require": "./dist/table.cjs"
        },
        "./card": {
            "types": "./dist/card.d.ts",
            "import": "./dist/card.js",
            "require": "./dist/card.cjs"
        },
        "./tabs": {
            "types": "./dist/tabs.d.ts",
            "import": "./dist/tabs.js",
            "require": "./dist/tabs.cjs"
        },
        "./style.css": "./dist/styles.css",
        "./index.css": "./dist/styles.css",
        "./styles.css": "./dist/styles.css",
        "./preflight.css": "./dist/preflight.css"
    },
    "files": [
        "dist"
    ],
    "sideEffects": [
        "**/*.css",
        "*.css"
    ],
    "scripts": {
        "build": "vite build && pnpm build:preflight",
        "build:preflight": "tailwindcss -i src/preflight.css -o dist/preflight.css",
        "prepack": "vite build",
        "dev": "vite build --watch",
        "clean": "rm -rf dist",
        "typecheck": "vue-tsc --noEmit",
        "lint": "eslint src",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "visual:dev": "vite --config visual/vite.config.ts --host 127.0.0.1",
        "test:visual": "vite build --config visual/vite.config.ts && playwright test --config playwright.config.ts",
        "test:visual:update": "vite build --config visual/vite.config.ts && playwright test --config playwright.config.ts --update-snapshots",
        "docs:api": "typedoc",
        "docs:api:full": "npx tsx scripts/generate-api-docs.ts",
        "docs:api:vue": "npx tsx scripts/generate-api-docs.ts --skip-typedoc"
    },
    "peerDependencies": {
        "@lucide/vue": "^1.0.0",
        "@tanstack/vue-virtual": "^3.0.0",
        "embla-carousel-vue": "^8.6.0",
        "prismjs": "^1.29.0",
        "reka-ui": "^2.9.0",
        "tailwindcss": "^4.0.0",
        "v-calendar": "^3.0.0",
        "vee-validate": "^4.0.0",
        "vue": "^3.5.0"
    },
    "peerDependenciesMeta": {
        "@lucide/vue": {
            "optional": true
        },
        "@tanstack/vue-virtual": {
            "optional": true
        },
        "embla-carousel-vue": {
            "optional": true
        },
        "prismjs": {
            "optional": true
        },
        "v-calendar": {
            "optional": true
        },
        "vee-validate": {
            "optional": true
        }
    },
    "dependencies": {
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.0",
        "tailwind-merge": "^3.6.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/cli": "^4.3.2",
        "@tailwindcss/vite": "^4.3.0",
        "@types/node": "^25.9.1",
        "@types/prismjs": "^1.26.6",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vitest/coverage-v8": "^4.1.8",
        "@vue/test-utils": "^2.4.11",
        "embla-carousel": "8.6.0",
        "eslint": "^10.4.1",
        "eslint-plugin-vue": "^10.9.2",
        "globals": "^17.6.0",
        "happy-dom": "^20.9.0",
        "tailwindcss": "^4.3.0",
        "tsx": "^4.22.4",
        "typedoc": "^0.28.19",
        "typedoc-plugin-markdown": "^4.12.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "vite": "^8.0.16",
        "vite-plugin-dts": "^5.0.2",
        "vitest": "^4.1.8",
        "vitest-axe": "^0.1.0",
        "vue": "^3.5.0",
        "vue-tsc": "^3.3.3"
    },
    "keywords": [
        "vue",
        "vue3",
        "ui",
        "ui-library",
        "ui-components",
        "components",
        "brutalism",
        "neo-brutalism",
        "brutalist",
        "design-system",
        "tailwindcss",
        "tailwind",
        "reka-ui",
        "typescript",
        "frontend",
        "accessible",
        "dark-mode"
    ],
    "author": "lidaixingchen",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/lidaixingchen/brutxui-vue3"
    },
    "publishConfig": {
        "access": "public"
    },
    "bugs": {
        "url": "https://github.com/lidaixingchen/brutxui-vue3/issues"
    },
    "homepage": "https://lidaixingchen.github.io/brutxui-vue3/"
}
