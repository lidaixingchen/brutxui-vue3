            "brutal-fg": "var(--brutal-fg)",
            "brutal-primary": "var(--brutal-primary)",
            "brutal-secondary": "var(--brutal-secondary)",
            "brutal-accent": "var(--brutal-accent)",
            "brutal-destructive": "var(--brutal-destructive)",
