{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "testimonial-card",
  "type": "registry:ui",
  "title": "Testimonial Card",
  "description": "A highly customizable neo-brutalist Testimonial Card component built with Brutx design tokens for Vue 3.",
  "dependencies": [
    "@lucide/vue"
  ],
  "registryDependencies": [
    "card",
    "avatar",
    "badge"
  ],
  "files": [
    {
      "path": "components/ui/testimonial-card/TestimonialCard.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { Quote } from '@lucide/vue'\nimport { cn } from '@/lib/utils'\nimport { useLocale } from '@/composables/useLocale'\nimport Card from '@/components/ui/card/Card.vue'\nimport CardContent from '@/components/ui/card/CardContent.vue'\nimport Avatar from '@/components/ui/avatar/Avatar.vue'\nimport AvatarFallback from '@/components/ui/avatar/AvatarFallback.vue'\nimport Badge from '@/components/ui/badge/Badge.vue'\n\ninterface TestimonialCardProps {\n    quote?: string\n    author?: string\n    role?: string\n    class?: string\n}\n\nconst props = withDefaults(defineProps<TestimonialCardProps>(), {\n    quote: undefined,\n    author: undefined,\n    role: undefined,\n    class: undefined,\n})\n\nconst { t } = useLocale()\n\nconst rootClasses = computed(() => cn('w-full max-w-lg', props.class))\n\nconst resolvedQuote = computed(() => props.quote ?? t('testimonialCard.defaultQuote'))\nconst resolvedAuthor = computed(() => props.author ?? t('testimonialCard.defaultAuthor'))\nconst resolvedRole = computed(() => props.role ?? t('testimonialCard.defaultRole'))\n\nconst resolvedVerified = computed(() => t('testimonialCard.verified'))\n\nconst initials = computed(() => {\n    return resolvedAuthor.value\n        .split(' ')\n        .map(w => w[0])\n        .join('')\n        .slice(0, 2)\n        .toUpperCase()\n})\n</script>\n\n<template>\n    <Card :class=\"rootClasses\" variant=\"default\">\n        <CardContent>\n            <div class=\"flex items-start gap-4\">\n                <div class=\"shrink-0\">\n                    <Avatar size=\"lg\" shape=\"square\">\n                        <AvatarFallback>{{ initials }}</AvatarFallback>\n                    </Avatar>\n                </div>\n                <div class=\"flex-1 min-w-0\">\n                    <Quote class=\"h-8 w-8 stroke-[2.5] text-brutal-primary mb-2\" />\n                    <p class=\"text-base font-bold leading-relaxed\">\n{{ resolvedQuote }}\n</p>\n                    <div class=\"mt-4 flex items-center gap-3\">\n                        <div>\n                            <p class=\"font-black text-sm\">\n{{ resolvedAuthor }}\n</p>\n                            <p class=\"text-xs text-brutal-muted-foreground font-medium\">\n{{ resolvedRole }}\n</p>\n                        </div>\n                        <Badge variant=\"secondary\" size=\"sm\">\n                            {{ resolvedVerified }}\n                        </Badge>\n                    </div>\n                </div>\n            </div>\n            <slot name=\"actions\" />\n        </CardContent>\n    </Card>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "composables/useLocale.ts",
      "content": "import { type ComputedRef, type InjectionKey, type MaybeRef, computed, inject, provide, unref } from 'vue'\nimport { zhCN } from '../locales/zh-CN'\nimport type { Locale } from '../locales/types'\n\nexport const LOCALE_INJECTION_KEY: InjectionKey<MaybeRef<Locale>> = Symbol('brutx-ui-locale')\n\nexport type TranslateFunction = (path: string, params?: Record<string, string | number>) => string\n\nexport function provideLocale(locale: MaybeRef<Locale>) {\n    provide(LOCALE_INJECTION_KEY, locale)\n}\n\nfunction resolveByPath(obj: unknown, path: string): string | undefined {\n    const keys = path.split('.')\n    let result: unknown = obj\n    for (const key of keys) {\n        if (result == null || typeof result !== 'object') return undefined\n        result = (result as Record<string, unknown>)[key]\n    }\n    return typeof result === 'string' ? result : undefined\n}\n\nfunction interpolate(template: string, params?: Record<string, string | number>): string {\n    if (!params) return template\n    return Object.entries(params).reduce(\n        (str, [k, v]) => str.split(`{${k}}`).join(String(v)),\n        template,\n    )\n}\n\nexport function useLocale(): { locale: ComputedRef<Locale>; t: TranslateFunction } {\n    const injected = inject<MaybeRef<Locale> | undefined>(LOCALE_INJECTION_KEY, undefined)\n\n    const locale = computed<Locale>(() => {\n        const resolved = injected ? unref(injected) : undefined\n        return resolved ?? zhCN\n    })\n\n    function t(path: string, params?: Record<string, string | number>): string {\n        const currentVal = resolveByPath(locale.value, path)\n        if (currentVal !== undefined) return interpolate(currentVal, params)\n\n        const fallbackVal = resolveByPath(zhCN, path)\n        if (fallbackVal !== undefined) return interpolate(fallbackVal, params)\n\n        return path\n    }\n\n    return { locale, t }\n}\n",
      "type": "registry:ui"
    }
  ],
  "tailwind": {
    "config": {
      "theme": {
        "extend": {
          "borderWidth": {
            "3": "var(--brutal-border-width, 3px)"
          },
