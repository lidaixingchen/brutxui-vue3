{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "upload",
  "type": "registry:ui",
  "title": "Upload",
  "description": "File upload with drag-and-drop, preview, and progress tracking.",
  "category": "form",
  "examples": [],
  "dependencies": [
    "@lucide/vue"
  ],
  "registryDependencies": [
