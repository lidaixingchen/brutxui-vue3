{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "breadcrumb",
  "type": "registry:ui",
  "title": "Breadcrumb",
  "description": "A highly customizable neo-brutalist Breadcrumb component built with Brutx design tokens for Vue 3.",
  "dependencies": [
    "reka-ui",
    "lucide-vue-next"
  ],
  "registryDependencies": [],
  "files": [
    {
      "path": "components/ui/breadcrumb/Breadcrumb.vue",
      "content": "<script setup lang=\"ts\">\ninterface BreadcrumbProps {\n    class?: string\n}\n\nconst props = withDefaults(defineProps<BreadcrumbProps>(), {\n    class: '',\n})\n</script>\n\n<template>\n    <nav aria-label=\"breadcrumb\" :class=\"props.class\">\n        <slot />\n    </nav>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/breadcrumb/BreadcrumbList.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { cn } from '@/lib/utils'\n\ninterface BreadcrumbListProps {\n    class?: string\n}\n\nconst props = withDefaults(defineProps<BreadcrumbListProps>(), {\n    class: '',\n})\n\nconst classes = computed(() =>\n    cn(\n        'flex flex-wrap items-center gap-1.5 break-words text-sm font-black text-brutal-fg sm:gap-2.5',\n        props.class\n    )\n)\n</script>\n\n<template>\n    <ol :class=\"classes\">\n        <slot />\n    </ol>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/breadcrumb/BreadcrumbItem.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { cn } from '@/lib/utils'\n\ninterface BreadcrumbItemProps {\n    class?: string\n}\n\nconst props = withDefaults(defineProps<BreadcrumbItemProps>(), {\n    class: '',\n})\n\nconst classes = computed(() =>\n    cn('inline-flex items-center gap-1.5', props.class)\n)\n</script>\n\n<template>\n    <li :class=\"classes\">\n        <slot />\n    </li>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/breadcrumb/BreadcrumbLink.vue",
      "content": "<script setup lang=\"ts\">\nimport { Primitive, type PrimitiveProps } from 'reka-ui'\nimport { computed } from 'vue'\nimport { cn } from '@/lib/utils'\n\ninterface BreadcrumbLinkProps extends PrimitiveProps {\n    class?: string\n}\n\nconst props = withDefaults(defineProps<BreadcrumbLinkProps>(), {\n    as: 'a',\n    class: '',\n})\n\nconst classes = computed(() =>\n    cn('transition-colors hover:text-brutal-primary hover:underline cursor-pointer', props.class)\n)\n</script>\n\n<template>\n    <Primitive\n        :as=\"props.as\"\n        :as-child=\"props.asChild\"\n        :class=\"classes\"\n    >\n        <slot />\n    </Primitive>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/breadcrumb/BreadcrumbPage.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { cn } from '@/lib/utils'\n\ninterface BreadcrumbPageProps {\n    class?: string\n}\n\nconst props = withDefaults(defineProps<BreadcrumbPageProps>(), {\n    class: '',\n})\n\nconst classes = computed(() =>\n    cn(\n        'font-black text-brutal-fg bg-brutal-accent px-2 py-0.5 border-2 border-brutal rounded-brutal shadow-brutal-sm select-none',\n        props.class\n    )\n)\n</script>\n\n<template>\n    <span\n        role=\"link\"\n        aria-disabled=\"true\"\n        aria-current=\"page\"\n        :class=\"classes\"\n    >\n        <slot />\n    </span>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/breadcrumb/BreadcrumbSeparator.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { cn } from '@/lib/utils'\n\ninterface BreadcrumbSeparatorProps {\n    class?: string\n}\n\nconst props = withDefaults(defineProps<BreadcrumbSeparatorProps>(), {\n    class: '',\n})\n\nconst classes = computed(() =>\n    cn('[&>svg]:w-3.5 [&>svg]:h-3.5 font-bold text-brutal-fg/60', props.class)\n)\n</script>\n\n<template>\n    <li\n        role=\"presentation\"\n        aria-hidden=\"true\"\n        :class=\"classes\"\n    >\n        <slot>\n            <span>/</span>\n        </slot>\n    </li>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/breadcrumb/BreadcrumbEllipsis.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { MoreHorizontal } from 'lucide-vue-next'\nimport { cn } from '@/lib/utils'\n\ninterface BreadcrumbEllipsisProps {\n    class?: string\n}\n\nconst props = withDefaults(defineProps<BreadcrumbEllipsisProps>(), {\n    class: '',\n})\n\nconst classes = computed(() =>\n    cn(\n        'flex h-7 w-7 items-center justify-center border-2 border-brutal bg-brutal-bg text-brutal-fg shadow-brutal-sm rounded-sm transition-all hover:bg-brutal-muted active:translate-y-[1px] active:shadow-none select-none cursor-pointer',\n        props.class\n    )\n)\n</script>\n\n<template>\n    <span\n        role=\"presentation\"\n        aria-hidden=\"true\"\n        :class=\"classes\"\n    >\n        <slot>\n            <MoreHorizontal class=\"h-4 w-4 stroke-[3]\" />\n        </slot>\n        <span class=\"sr-only\">More</span>\n    </span>\n</template>\n",
      "type": "registry:ui"
    }
  ],
