{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "header-section",
  "type": "registry:ui",
  "title": "Header Section",
  "description": "A highly customizable neo-brutalist Header Section component built with Brutx design tokens for Vue 3.",
  "dependencies": [
    "reka-ui",
    "@lucide/vue"
  ],
  "registryDependencies": [
    "button",
    "sheet",
    "separator"
  ],
  "files": [
    {
      "path": "components/ui/header-section/HeaderSection.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed, ref } from 'vue'\nimport { DialogRoot } from 'reka-ui'\nimport { Menu } from '@lucide/vue'\nimport { cn } from '@/lib/utils'\nimport { useLocale } from '@/composables/useLocale'\nimport Button from '@/components/ui/button/Button.vue'\nimport SheetContent from '@/components/ui/sheet/SheetContent.vue'\nimport SheetHeader from '@/components/ui/sheet/SheetHeader.vue'\nimport SheetTitle from '@/components/ui/sheet/SheetTitle.vue'\nimport SheetDescription from '@/components/ui/sheet/SheetDescription.vue'\nimport Separator from '@/components/ui/separator/Separator.vue'\n\nexport interface NavItem {\n    label: string\n    href?: string\n}\n\ninterface HeaderSectionProps {\n    logoText?: string\n    navItems?: NavItem[]\n    ctaText?: string\n    class?: string\n}\n\nconst props = withDefaults(defineProps<HeaderSectionProps>(), {\n    logoText: undefined,\n    navItems: () => [],\n    ctaText: undefined,\n    class: undefined,\n})\n\nconst emit = defineEmits<{\n    'cta-click': []\n    'nav-click': [index: number]\n}>()\n\nconst { t } = useLocale()\n\nconst resolvedLogoText = computed(() => props.logoText ?? t('headerSection.defaultLogoText'))\nconst resolvedCtaText = computed(() => props.ctaText ?? t('headerSection.defaultCtaText'))\nconst menuLabel = computed(() => t('headerSection.menuLabel'))\n\nconst mobileMenuOpen = ref(false)\n\nconst rootClasses = computed(() =>\n    cn(\n        'sticky top-0 z-40 w-full',\n        'bg-brutal-bg border-b-3 border-brutal shadow-brutal-sm',\n        props.class\n    )\n)\n</script>\n\n<template>\n    <header :class=\"rootClasses\">\n        <div class=\"flex h-16 items-center justify-between px-4 md:px-6 max-w-7xl mx-auto\">\n            <slot name=\"header\">\n                <span class=\"text-xl font-black tracking-tight text-brutal-fg\">\n                    {{ resolvedLogoText }}\n                </span>\n            </slot>\n\n            <slot>\n                <nav class=\"hidden md:flex items-center gap-1\">\n                    <Button\n                        v-for=\"(item, index) in navItems\"\n                        :key=\"index\"\n                        variant=\"ghost\"\n                        size=\"sm\"\n                        @click=\"emit('nav-click', index)\"\n                    >\n                        {{ item.label }}\n                    </Button>\n                </nav>\n            </slot>\n\n            <div class=\"flex items-center gap-3\">\n                <slot name=\"footer\">\n                    <Button\n                        variant=\"primary\"\n                        size=\"sm\"\n                        class=\"hidden md:inline-flex\"\n                        @click=\"emit('cta-click')\"\n                    >\n                        {{ resolvedCtaText }}\n                    </Button>\n                </slot>\n\n                <Button\n                    variant=\"outline\"\n                    size=\"sm\"\n                    class=\"md:hidden\"\n                    @click=\"mobileMenuOpen = true\"\n                >\n                    <Menu class=\"h-5 w-5\" />\n                    <span class=\"sr-only\">{{ menuLabel }}</span>\n                </Button>\n            </div>\n        </div>\n\n        <DialogRoot v-model:open=\"mobileMenuOpen\">\n            <SheetContent side=\"right\">\n                <SheetHeader>\n                    <SheetTitle>{{ resolvedLogoText }}</SheetTitle>\n                    <SheetDescription>{{ menuLabel }}</SheetDescription>\n                </SheetHeader>\n                <nav class=\"flex flex-col gap-2 py-4\">\n                    <Button\n                        v-for=\"(item, index) in navItems\"\n                        :key=\"index\"\n                        variant=\"ghost\"\n                        class=\"justify-start\"\n                        @click=\"emit('nav-click', index); mobileMenuOpen = false\"\n                    >\n                        {{ item.label }}\n                    </Button>\n                </nav>\n                <Separator />\n                <div class=\"pt-4\">\n                    <Button\n                        variant=\"primary\"\n                        class=\"w-full\"\n                        @click=\"emit('cta-click'); mobileMenuOpen = false\"\n                    >\n                        {{ resolvedCtaText }}\n                    </Button>\n                </div>\n            </SheetContent>\n        </DialogRoot>\n    </header>\n</template>\n",
      "type": "registry:ui"
    }
  ],
  "tailwind": {
