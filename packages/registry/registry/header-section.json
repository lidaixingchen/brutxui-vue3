  "files": [
    {
      "path": "components/ui/header-section/HeaderSection.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed, ref } from 'vue'\nimport { DialogRoot } from 'reka-ui'\nimport { Menu } from '@lucide/vue'\nimport { cn } from '@/lib/utils'\nimport { useLocale } from '@/composables/useLocale'\nimport { iconSizeVariants, type IconSize } from '@/lib/icon-size-variants'\nimport Button from '@/components/ui/button/Button.vue'\nimport SheetContent from '@/components/ui/sheet/SheetContent.vue'\nimport SheetHeader from '@/components/ui/sheet/SheetHeader.vue'\nimport SheetTitle from '@/components/ui/sheet/SheetTitle.vue'\nimport SheetDescription from '@/components/ui/sheet/SheetDescription.vue'\nimport Separator from '@/components/ui/separator/Separator.vue'\nimport type { NavItem } from '@/components/ui/header-section/types'\n\nexport type { NavItem };\n\ninterface HeaderSectionProps {\n    logoText?: string\n    navItems?: NavItem[]\n    ctaText?: string\n    class?: string\n    iconSize?: IconSize\n}\n\nconst props = withDefaults(defineProps<HeaderSectionProps>(), {\n    logoText: undefined,\n    navItems: () => [],\n    ctaText: undefined,\n    class: undefined,\n    iconSize: 'lg',\n})\n\nconst emit = defineEmits<{\n    'cta-click': []\n    'nav-click': [index: number]\n}>()\n\nconst { t } = useLocale()\n\nconst resolvedLogoText = computed(() => props.logoText ?? t('headerSection.defaultLogoText'))\nconst resolvedCtaText = computed(() => props.ctaText ?? t('headerSection.defaultCtaText'))\nconst menuLabel = computed(() => t('headerSection.menuLabel'))\n\nconst mobileMenuOpen = ref(false)\n\nconst rootClasses = computed(() =>\n    cn(\n        'sticky top-0 z-40 w-full',\n        'bg-brutal-bg border-b-3 border-brutal shadow-brutal-sm',\n        props.class\n    )\n)\n\nconst menuIconClasses = computed(() => iconSizeVariants({ size: props.iconSize }))\n</script>\n\n<template>\n    <header :class=\"rootClasses\">\n        <div class=\"flex h-16 items-center justify-between px-4 md:px-6 max-w-7xl mx-auto\">\n            <slot name=\"header\">\n                <span class=\"text-xl font-black tracking-tight text-brutal-fg\">\n                    {{ resolvedLogoText }}\n                </span>\n            </slot>\n\n            <slot>\n                <nav class=\"hidden md:flex items-center gap-1\">\n                    <Button\n                        v-for=\"(item, index) in navItems\"\n                        :key=\"index\"\n                        variant=\"ghost\"\n                        size=\"sm\"\n                        @click=\"emit('nav-click', index)\"\n                    >\n                        {{ item.label }}\n                    </Button>\n                </nav>\n            </slot>\n\n            <div class=\"flex items-center gap-3\">\n                <slot name=\"footer\">\n                    <Button\n                        variant=\"primary\"\n                        size=\"sm\"\n                        class=\"hidden md:inline-flex\"\n                        @click=\"emit('cta-click')\"\n                    >\n                        {{ resolvedCtaText }}\n                    </Button>\n                </slot>\n\n                <Button\n                    variant=\"outline\"\n                    size=\"sm\"\n                    class=\"md:hidden\"\n                    @click=\"mobileMenuOpen = true\"\n                >\n                    <Menu :class=\"menuIconClasses\" />\n                    <span class=\"sr-only\">{{ menuLabel }}</span>\n                </Button>\n            </div>\n        </div>\n\n        <DialogRoot v-model:open=\"mobileMenuOpen\">\n            <SheetContent side=\"right\">\n                <SheetHeader>\n                    <SheetTitle>{{ resolvedLogoText }}</SheetTitle>\n                    <SheetDescription>{{ menuLabel }}</SheetDescription>\n                </SheetHeader>\n                <nav class=\"flex flex-col gap-2 py-4\">\n                    <Button\n                        v-for=\"(item, index) in navItems\"\n                        :key=\"index\"\n                        variant=\"ghost\"\n                        class=\"justify-start\"\n                        @click=\"emit('nav-click', index); mobileMenuOpen = false\"\n                    >\n                        {{ item.label }}\n                    </Button>\n                </nav>\n                <Separator />\n                <div class=\"pt-4\">\n                    <Button\n                        variant=\"primary\"\n                        class=\"w-full\"\n                        @click=\"emit('cta-click'); mobileMenuOpen = false\"\n                    >\n                        {{ resolvedCtaText }}\n                    </Button>\n                </div>\n            </SheetContent>\n        </DialogRoot>\n    </header>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/header-section/types.ts",
      "content": "export interface NavItem {\n    label: string\n    href?: string\n}\n",
      "type": "registry:lib"
    },
    {
      "path": "composables/useLocale.ts",
      "content": "import { type ComputedRef, type InjectionKey, type MaybeRef, computed, inject, provide, unref } from 'vue'\nimport { zhCN } from '@/locales/zh-CN'\nimport type { Locale } from '@/locales/types'\n\nexport const LOCALE_INJECTION_KEY: InjectionKey<MaybeRef<Locale>> = Symbol('brutx-ui-locale')\nexport const FALLBACK_LOCALE_INJECTION_KEY: InjectionKey<MaybeRef<Partial<Locale>>> = Symbol('brutx-ui-fallback-locale')\n\nexport type TranslateFunction = (path: string, params?: Record<string, string | number>) => string\n\nexport interface LocaleOptions {\n    locale: MaybeRef<Locale>\n    fallbackLocale?: MaybeRef<Partial<Locale>>\n}\n\nexport function provideLocale(localeOrOptions: MaybeRef<Locale> | LocaleOptions): void {\n    // 检查是否是 LocaleOptions 格式（包含 locale 属性）\n    if (\n        typeof localeOrOptions === 'object' &&\n        localeOrOptions !== null &&\n        'locale' in localeOrOptions\n    ) {\n        const options = localeOrOptions as LocaleOptions\n        provide(LOCALE_INJECTION_KEY, options.locale)\n        if (options.fallbackLocale) {\n            provide(FALLBACK_LOCALE_INJECTION_KEY, options.fallbackLocale)\n        }\n    } else {\n        // 直接传入 MaybeRef<Locale> 格式（向后兼容）\n        provide(LOCALE_INJECTION_KEY, localeOrOptions as MaybeRef<Locale>)\n    }\n}\n\nfunction resolveByPath(obj: unknown, path: string): string | undefined {\n    const keys = path.split('.')\n    let result: unknown = obj\n    for (const key of keys) {\n        if (typeof result !== 'object' || result === null) return undefined\n        result = (result as Record<string, unknown>)[key]\n    }\n    return typeof result === 'string' ? result : undefined\n}\n\nfunction interpolate(template: string, params?: Record<string, string | number>): string {\n    if (!params) return template\n    return Object.entries(params).reduce(\n        (str, [k, v]) => str.split(`{${k}}`).join(String(v)),\n        template,\n    )\n}\n\nexport function useLocale(): { locale: ComputedRef<Locale>; t: TranslateFunction } {\n    const injected = inject<MaybeRef<Locale> | undefined>(LOCALE_INJECTION_KEY, undefined)\n    const injectedFallback = inject<MaybeRef<Partial<Locale>> | undefined>(FALLBACK_LOCALE_INJECTION_KEY, undefined)\n\n    const locale = computed<Locale>(() => {\n        const resolved = injected ? unref(injected) : undefined\n        return resolved ?? zhCN\n    })\n\n    const fallbackLocale = computed<Partial<Locale>>(() => {\n        return injectedFallback ? unref(injectedFallback) : {}\n    })\n\n    function t(path: string, params?: Record<string, string | number>): string {\n        // 1. 尝试从用户 locale 查找\n        const currentVal = resolveByPath(locale.value, path)\n        if (currentVal !== undefined) return interpolate(currentVal, params)\n\n        // 2. 尝试从自定义 fallback locale 查找\n        if (fallbackLocale.value && Object.keys(fallbackLocale.value).length > 0) {\n            const fallbackVal = resolveByPath(fallbackLocale.value, path)\n            if (fallbackVal !== undefined) return interpolate(fallbackVal, params)\n        }\n\n        // 3. 尝试从默认 zhCN 查找\n        const zhCNVal = resolveByPath(zhCN, path)\n        if (zhCNVal !== undefined) return interpolate(zhCNVal, params)\n\n        // 4. 返回 path 原文\n        return path\n    }\n\n    return { locale, t }\n}\n",
      "type": "registry:hook"
    },
    {
      "path": "lib/icon-size-variants.ts",
      "content": "import { cva, type VariantProps } from 'class-variance-authority'\n\nexport const iconSizeVariants = cva('', {\n    variants: {\n        size: {\n            xs: 'h-2.5 w-2.5',\n            sm: 'h-3 w-3',\n            default: 'h-4 w-4',\n            lg: 'h-5 w-5',\n            xl: 'h-6 w-6',\n            '2xl': 'h-8 w-8',\n        },\n    },\n    defaultVariants: { size: 'default' },\n})\n\nexport type IconSize = NonNullable<VariantProps<typeof iconSizeVariants>['size']>\n",
      "type": "registry:lib"
    }
  ],
