{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "footer-section",
  "type": "registry:ui",
  "title": "Footer Section",
  "description": "A highly customizable neo-brutalist Footer Section component built with Brutx design tokens for Vue 3.",
  "dependencies": [
    "@lucide/vue"
  ],
  "registryDependencies": [
    "button",
    "separator"
  ],
  "files": [
    {
      "path": "components/ui/footer-section/FooterSection.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { cn } from '@/lib/utils'\nimport { useLocale } from '@/composables/useLocale'\nimport Button from '@/components/ui/button/Button.vue'\nimport Separator from '@/components/ui/separator/Separator.vue'\n\nexport interface FooterLink {\n    label: string\n    href?: string\n}\n\nexport interface FooterLinkGroup {\n    title: string\n    links: FooterLink[]\n}\n\ninterface FooterSectionProps {\n    logoText?: string\n    description?: string\n    linkGroups?: FooterLinkGroup[]\n    copyright?: string\n    class?: string\n}\n\nconst props = withDefaults(defineProps<FooterSectionProps>(), {\n    logoText: undefined,\n    description: undefined,\n    linkGroups: () => [],\n    copyright: undefined,\n    class: undefined,\n})\n\nconst emit = defineEmits<{\n    'link-click': [payload: { groupIndex: number; linkIndex: number }]\n}>()\n\nconst { t } = useLocale()\n\nconst resolvedLogoText = computed(() => props.logoText ?? t('footerSection.defaultLogoText'))\nconst resolvedDescription = computed(() => props.description ?? t('footerSection.defaultDescription'))\nconst resolvedCopyright = computed(() => props.copyright ?? t('footerSection.defaultCopyright'))\n\nconst rootClasses = computed(() =>\n    cn(\n        'w-full',\n        'bg-brutal-bg border-t-3 border-brutal',\n        props.class\n    )\n)\n</script>\n\n<template>\n    <footer :class=\"rootClasses\">\n        <div class=\"max-w-7xl mx-auto px-4 md:px-6 py-10\">\n            <slot name=\"header\">\n                <div class=\"mb-8\">\n                    <span class=\"text-xl font-black tracking-tight text-brutal-fg\">\n                        {{ resolvedLogoText }}\n                    </span>\n                    <p v-if=\"resolvedDescription\" class=\"mt-2 text-sm text-brutal-muted-foreground font-medium max-w-sm\">\n                        {{ resolvedDescription }}\n                    </p>\n                </div>\n            </slot>\n\n            <slot>\n                <div v-if=\"linkGroups.length > 0\" class=\"grid grid-cols-2 md:grid-cols-4 gap-8 mb-8\">\n                    <div v-for=\"(group, groupIndex) in linkGroups\" :key=\"groupIndex\">\n                        <h3 class=\"font-black text-sm tracking-wide text-brutal-fg mb-3\">\n                            {{ group.title }}\n                        </h3>\n                        <ul class=\"space-y-2 list-none\">\n                            <li v-for=\"(link, linkIndex) in group.links\" :key=\"linkIndex\" class=\"flex items-center gap-2\">\n                                <span class=\"h-1.5 w-1.5 bg-brutal-fg flex-shrink-0\"></span>\n                                <a\n                                    v-if=\"link.href\"\n                                    :href=\"link.href\"\n                                    class=\"px-0 text-brutal-muted-foreground hover:text-brutal-fg text-sm font-medium cursor-pointer active:translate-y-[var(--brutal-pressed-offset,2px)] active:shadow-none transition-all\"\n                                    @click=\"emit('link-click', { groupIndex, linkIndex })\"\n                                >\n                                    {{ link.label }}\n                                </a>\n                                <Button\n                                    v-else\n                                    variant=\"ghost\"\n                                    size=\"sm\"\n                                    class=\"px-0 text-brutal-muted-foreground hover:text-brutal-fg\"\n                                    @click=\"emit('link-click', { groupIndex, linkIndex })\"\n                                >\n                                    {{ link.label }}\n                                </Button>\n                            </li>\n                        </ul>\n                    </div>\n                </div>\n            </slot>\n\n            <Separator />\n\n            <slot name=\"footer\">\n                <div class=\"pt-6 text-center\">\n                    <p class=\"text-sm text-brutal-muted-foreground font-medium\">\n                        {{ resolvedCopyright }}\n                    </p>\n                </div>\n            </slot>\n        </div>\n    </footer>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "composables/useLocale.ts",
      "content": "import { type ComputedRef, type InjectionKey, type MaybeRef, computed, inject, provide, unref } from 'vue'\nimport { zhCN } from '../locales/zh-CN'\nimport type { Locale } from '../locales/types'\n\nexport const LOCALE_INJECTION_KEY: InjectionKey<MaybeRef<Locale>> = Symbol('brutx-ui-locale')\n\nexport type TranslateFunction = (path: string, params?: Record<string, string | number>) => string\n\nexport function provideLocale(locale: MaybeRef<Locale>) {\n    provide(LOCALE_INJECTION_KEY, locale)\n}\n\nfunction resolveByPath(obj: unknown, path: string): string | undefined {\n    const keys = path.split('.')\n    let result: unknown = obj\n    for (const key of keys) {\n        if (result == null || typeof result !== 'object') return undefined\n        result = (result as Record<string, unknown>)[key]\n    }\n    return typeof result === 'string' ? result : undefined\n}\n\nfunction interpolate(template: string, params?: Record<string, string | number>): string {\n    if (!params) return template\n    return Object.entries(params).reduce(\n        (str, [k, v]) => str.split(`{${k}}`).join(String(v)),\n        template,\n    )\n}\n\nexport function useLocale(): { locale: ComputedRef<Locale>; t: TranslateFunction } {\n    const injected = inject<MaybeRef<Locale> | undefined>(LOCALE_INJECTION_KEY, undefined)\n\n    const locale = computed<Locale>(() => {\n        const resolved = injected ? unref(injected) : undefined\n        return resolved ?? zhCN\n    })\n\n    function t(path: string, params?: Record<string, string | number>): string {\n        const currentVal = resolveByPath(locale.value, path)\n        if (currentVal !== undefined) return interpolate(currentVal, params)\n\n        const fallbackVal = resolveByPath(zhCN, path)\n        if (fallbackVal !== undefined) return interpolate(fallbackVal, params)\n\n        return path\n    }\n\n    return { locale, t }\n}\n",
      "type": "registry:ui"
    }
  ],
