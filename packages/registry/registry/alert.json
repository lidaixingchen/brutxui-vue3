    },
    "dark": {
      "brutal-border-width": "3px",
      "brutal-border-color": "#ffffff",
      "brutal-shadow-offset-x": "4px",
      "brutal-shadow-offset-y": "4px",
      "brutal-shadow-color": "#ffffff",
      "brutal-radius": "0px",
      "brutal-pressed-offset": "2px",
      "brutal-bg": "#141414",
      "brutal-fg": "#ffffff",
      "brutal-primary": "#FF6B6B",
