{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "brutalist-hero",
  "type": "registry:ui",
  "title": "Brutalist Hero",
  "description": "A highly customizable neo-brutalist Brutalist Hero component built with Brutx design tokens for Vue 3.",
  "dependencies": [
    "@lucide/vue"
  ],
  "registryDependencies": [
    "button",
    "card"
  ],
  "files": [
    {
      "path": "components/ui/brutalist-hero/BrutalistHero.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { ArrowRight, Sparkles } from '@lucide/vue'\nimport { cn } from '@/lib/utils'\nimport { useLocale } from '@/composables/useLocale'\nimport Button from '@/components/ui/button/Button.vue'\nimport Card from '@/components/ui/card/Card.vue'\nimport CardContent from '@/components/ui/card/CardContent.vue'\n\ninterface BrutalistHeroProps {\n    title?: string\n    subtitle?: string\n    primaryCtaText?: string\n    secondaryCtaText?: string\n    class?: string\n}\n\nconst props = withDefaults(defineProps<BrutalistHeroProps>(), {\n    title: undefined,\n    subtitle: undefined,\n    primaryCtaText: undefined,\n    secondaryCtaText: undefined,\n    class: undefined,\n})\n\nconst { t } = useLocale()\n\nconst resolvedTitle = computed(() => props.title ?? t('brutalistHero.title'))\nconst resolvedSubtitle = computed(() => props.subtitle ?? t('brutalistHero.defaultSubtitle'))\nconst resolvedPrimaryCtaText = computed(() => props.primaryCtaText ?? t('brutalistHero.primaryCtaText'))\nconst resolvedSecondaryCtaText = computed(() => props.secondaryCtaText ?? t('brutalistHero.secondaryCtaText'))\n\nconst emit = defineEmits<{\n    primaryCta: []\n    secondaryCta: []\n}>()\n\nconst rootClasses = computed(() => cn('w-full', props.class))\n</script>\n\n<template>\n    <div :class=\"rootClasses\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 items-center\">\n            <div>\n                <div class=\"inline-flex items-center gap-2 mb-6 bg-brutal-accent px-3 py-1 border-3 border-brutal rotate-[-1deg]\">\n                    <Sparkles class=\"h-4 w-4 stroke-[3]\" />\n                    <span class=\"font-black text-sm\">{{ t('brutalistHero.neoBrutalismUI') }}</span>\n                </div>\n                <h1 class=\"text-4xl lg:text-5xl font-black tracking-tight leading-tight\">\n{{ resolvedTitle }}\n</h1>\n                <p v-if=\"resolvedSubtitle\" class=\"mt-4 text-lg text-brutal-muted-foreground font-medium\">\n{{ resolvedSubtitle }}\n</p>\n                <div class=\"mt-8 flex flex-wrap gap-4\">\n                    <Button variant=\"primary\" size=\"lg\" @click=\"emit('primaryCta')\">\n                        {{ resolvedPrimaryCtaText }}\n                        <ArrowRight class=\"ml-2 h-5 w-5 stroke-[3]\" />\n                    </Button>\n                    <Button variant=\"outline\" size=\"lg\" @click=\"emit('secondaryCta')\">\n{{ resolvedSecondaryCtaText }}\n</Button>\n                </div>\n            </div>\n\n            <div class=\"relative\">\n                <div class=\"absolute inset-0 bg-brutal-primary border-3 border-brutal translate-x-3 translate-y-3\" />\n                <Card variant=\"default\" padding=\"default\" class=\"relative bg-brutal-bg font-mono text-sm\">\n                    <CardContent>\n                        <div class=\"space-y-1\">\n                            <p class=\"text-brutal-muted-foreground\">\n$ npx brutxui init\n</p>\n                            <p class=\"text-brutal-success font-bold\">\n✓ Project initialized\n</p>\n                            <p class=\"text-brutal-muted-foreground\">\n$ npx brutxui add button\n</p>\n                            <p class=\"text-brutal-success font-bold\">\n✓ Button component added\n</p>\n                            <p class=\"text-brutal-muted-foreground\">\n$ npx brutxui add card dialog\n</p>\n                            <p class=\"text-brutal-success font-bold\">\n✓ 2 components added\n</p>\n                            <p class=\"text-brutal-accent font-bold animate-pulse\">\n█\n</p>\n                        </div>\n                    </CardContent>\n                </Card>\n            </div>\n        </div>\n    </div>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "composables/useLocale.ts",
      "content": "import { type ComputedRef, type InjectionKey, type MaybeRef, computed, inject, provide, unref } from 'vue'\nimport { zhCN } from '../locales/zh-CN'\nimport type { Locale } from '../locales/types'\n\nexport const LOCALE_INJECTION_KEY: InjectionKey<MaybeRef<Locale>> = Symbol('brutx-ui-locale')\n\nexport type TranslateFunction = (path: string, params?: Record<string, string | number>) => string\n\nexport function provideLocale(locale: MaybeRef<Locale>) {\n    provide(LOCALE_INJECTION_KEY, locale)\n}\n\nfunction resolveByPath(obj: unknown, path: string): string | undefined {\n    const keys = path.split('.')\n    let result: unknown = obj\n    for (const key of keys) {\n        if (result == null || typeof result !== 'object') return undefined\n        result = (result as Record<string, unknown>)[key]\n    }\n    return typeof result === 'string' ? result : undefined\n}\n\nfunction interpolate(template: string, params?: Record<string, string | number>): string {\n    if (!params) return template\n    return Object.entries(params).reduce(\n        (str, [k, v]) => str.split(`{${k}}`).join(String(v)),\n        template,\n    )\n}\n\nexport function useLocale(): { locale: ComputedRef<Locale>; t: TranslateFunction } {\n    const injected = inject<MaybeRef<Locale> | undefined>(LOCALE_INJECTION_KEY, undefined)\n\n    const locale = computed<Locale>(() => {\n        const resolved = injected ? unref(injected) : undefined\n        return resolved ?? zhCN\n    })\n\n    function t(path: string, params?: Record<string, string | number>): string {\n        const currentVal = resolveByPath(locale.value, path)\n        if (currentVal !== undefined) return interpolate(currentVal, params)\n\n        const fallbackVal = resolveByPath(zhCN, path)\n        if (fallbackVal !== undefined) return interpolate(fallbackVal, params)\n\n        return path\n    }\n\n    return { locale, t }\n}\n",
      "type": "registry:ui"
    }
  ],
  "tailwind": {
