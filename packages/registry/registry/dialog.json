{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "dialog",
  "type": "registry:ui",
  "title": "Dialog",
  "description": "A highly customizable neo-brutalist Dialog component built with Brutx design tokens for Vue 3.",
  "dependencies": [
    "reka-ui",
    "lucide-vue-next"
  ],
  "registryDependencies": [],
  "files": [
    {
      "path": "components/ui/dialog/DialogContent.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport {\n    DialogPortal as DialogPortalPrimitive,\n    DialogContent as DialogContentPrimitive,\n    DialogClose as DialogClosePrimitive,\n} from 'reka-ui'\nimport { X } from 'lucide-vue-next'\nimport { cn } from '@/lib/utils'\nimport DialogOverlay from '@/components/ui/dialog/DialogOverlay.vue'\n\ninterface DialogContentProps {\n    showCloseButton?: boolean\n    class?: string\n}\n\nconst props = withDefaults(defineProps<DialogContentProps>(), {\n    showCloseButton: true,\n})\n\nconst contentClasses = computed(() =>\n    cn(\n        'fixed left-[50%] top-[50%] z-50 translate-x-[-50%] translate-y-[-50%]',\n        'w-full max-w-lg p-6',\n        'bg-brutal-bg text-brutal-fg border-3 border-brutal shadow-brutal-xl',\n        'duration-200',\n        'data-[state=open]:animate-in data-[state=closed]:animate-out',\n        'data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0',\n        'data-[state=closed]:zoom-out-95 data-[state=open]:zoom-in-95',\n        'data-[state=closed]:slide-out-to-left-1/2 data-[state=closed]:slide-out-to-top-[48%]',\n        'data-[state=open]:slide-in-from-left-1/2 data-[state=open]:slide-in-from-top-[48%]',\n        props.class\n    )\n)\n\nconst closeClasses = computed(() =>\n    cn(\n        'absolute right-4 top-4',\n        'h-8 w-8 flex items-center justify-center',\n        'border-3 border-brutal bg-brutal-bg text-brutal-fg',\n        'shadow-brutal-sm',\n        'transition-all duration-150',\n        'hover:bg-brutal-destructive hover:text-brutal-fg',\n        'hover:shadow-brutal hover:-translate-x-0.5 hover:-translate-y-0.5',\n        'active:translate-y-[var(--brutal-pressed-offset,2px)] active:shadow-none',\n        'focus:outline-none focus:ring-2 focus:ring-brutal-ring focus:ring-offset-2'\n    )\n)\n</script>\n\n<template>\n    <DialogPortalPrimitive>\n        <DialogOverlay />\n        <DialogContentPrimitive :class=\"contentClasses\">\n            <slot />\n            <DialogClosePrimitive v-if=\"showCloseButton\" :class=\"closeClasses\">\n                <X class=\"h-4 w-4 stroke-[3]\" />\n                <span class=\"sr-only\">Close</span>\n            </DialogClosePrimitive>\n        </DialogContentPrimitive>\n    </DialogPortalPrimitive>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/dialog/DialogDescription.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { DialogDescription as DialogDescriptionPrimitive } from 'reka-ui'\nimport { cn } from '@/lib/utils'\n\ninterface DialogDescriptionProps {\n    class?: string\n}\n\nconst props = defineProps<DialogDescriptionProps>()\n\nconst classes = computed(() =>\n    cn('text-sm text-brutal-muted-foreground font-medium', props.class)\n)\n</script>\n\n<template>\n    <DialogDescriptionPrimitive :class=\"classes\">\n        <slot />\n    </DialogDescriptionPrimitive>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/dialog/DialogFooter.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { cn } from '@/lib/utils'\n\ninterface DialogFooterProps {\n    class?: string\n}\n\nconst props = defineProps<DialogFooterProps>()\n\nconst classes = computed(() =>\n    cn('flex flex-col-reverse sm:flex-row sm:justify-end sm:space-x-3 pt-4 border-t-3 border-brutal', props.class)\n)\n</script>\n\n<template>\n    <div :class=\"classes\">\n        <slot />\n    </div>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/dialog/DialogHeader.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { cn } from '@/lib/utils'\n\ninterface DialogHeaderProps {\n    class?: string\n}\n\nconst props = defineProps<DialogHeaderProps>()\n\nconst classes = computed(() =>\n    cn('flex flex-col space-y-2 pb-4 border-b-3 border-brutal', props.class)\n)\n</script>\n\n<template>\n    <div :class=\"classes\">\n        <slot />\n    </div>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/dialog/DialogOverlay.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { DialogOverlay as DialogOverlayPrimitive } from 'reka-ui'\nimport { cn } from '@/lib/utils'\n\ninterface DialogOverlayProps {\n    class?: string\n}\n\nconst props = defineProps<DialogOverlayProps>()\n\nconst classes = computed(() =>\n    cn(\n        'fixed inset-0 z-50 bg-brutal-overlay',\n        'data-[state=open]:animate-in data-[state=closed]:animate-out',\n        'data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0',\n        props.class\n    )\n)\n</script>\n\n<template>\n    <DialogOverlayPrimitive :class=\"classes\" />\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/dialog/DialogTitle.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { DialogTitle as DialogTitlePrimitive } from 'reka-ui'\nimport { cn } from '@/lib/utils'\n\ninterface DialogTitleProps {\n    class?: string\n}\n\nconst props = defineProps<DialogTitleProps>()\n\nconst classes = computed(() =>\n    cn('text-xl font-black tracking-tight', props.class)\n)\n</script>\n\n<template>\n    <DialogTitlePrimitive :class=\"classes\">\n        <slot />\n    </DialogTitlePrimitive>\n</template>\n",
      "type": "registry:ui"
    }
  ],
  "tailwind": {
    "config": {
      "theme": {
        "extend": {
          "borderWidth": {
            "3": "var(--brutal-border-width, 3px)"
          },
          "borderColor": {
            "brutal": "var(--brutal-border-color, #000000)"
          },
          "borderRadius": {
            "brutal": "var(--brutal-radius, 0px)"
          },
          "colors": {
            "brutal-bg": "var(--brutal-bg, #ffffff)",
            "brutal-fg": "var(--brutal-fg, #000000)",
            "brutal-primary": "var(--brutal-primary, #FF6B6B)",
            "brutal-secondary": "var(--brutal-secondary, #4ECDC4)",
            "brutal-accent": "var(--brutal-accent, #FFE66D)",
            "brutal-destructive": "var(--brutal-destructive, #EF476F)",
            "brutal-success": "var(--brutal-success, #7FB069)",
            "brutal-muted": "var(--brutal-muted, #f3f4f6)",
            "brutal-ring": "var(--brutal-ring, #000000)"
          },
          "boxShadow": {
            "brutal": "var(--brutal-shadow-offset-x, 4px) var(--brutal-shadow-offset-y, 4px) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-sm": "calc(var(--brutal-shadow-offset-x, 4px) / 2) calc(var(--brutal-shadow-offset-y, 4px) / 2) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-lg": "calc(var(--brutal-shadow-offset-x, 4px) * 1.5) calc(var(--brutal-shadow-offset-y, 4px) * 1.5) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-xl": "calc(var(--brutal-shadow-offset-x, 4px) * 2) calc(var(--brutal-shadow-offset-y, 4px) * 2) 0px 0px var(--brutal-shadow-color, #000000)"
          }
        }
      }
    }
  },
  "cssVars": {
