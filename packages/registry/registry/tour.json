{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "tour",
  "type": "registry:ui",
  "title": "Tour",
  "description": "Neo-Brutalist step-by-step interactive onboarding tour component with Canvas mask highlight.",
  "dependencies": [],
