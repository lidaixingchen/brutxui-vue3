{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "transfer",
  "type": "registry:ui",
  "title": "Transfer",
  "description": "Dual-panel transfer list for moving items between source and target collections.",
  "dependencies": [
    "@lucide/vue"
  ],
