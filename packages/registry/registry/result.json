{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "result",
  "type": "registry:ui",
  "title": "Result",
  "description": "Feedback result display with state color blocks and action buttons.",
  "dependencies": [
    "@lucide/vue"
  ],
  "registryDependencies": [],
  "files": [
    {
      "path": "components/ui/result/Result.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { Check, AlertTriangle, Info, X } from '@lucide/vue'\nimport { cn } from '@/lib/utils'\n\ninterface ResultProps {\n    status?: 'success' | 'warning' | 'info' | 'error'\n    title?: string\n    subTitle?: string\n    class?: string\n}\n\nconst props = withDefaults(defineProps<ResultProps>(), {\n    status: 'info',\n    title: undefined,\n    subTitle: undefined,\n    class: undefined,\n})\n\nconst statusConfig = {\n    success: {\n        icon: Check,\n        colorClass: 'bg-[#22c55e] text-brutal-black dark:text-white',\n    },\n    warning: {\n        icon: AlertTriangle,\n        colorClass: 'bg-brutal-yellow text-brutal-black',\n    },\n    info: {\n        icon: Info,\n        colorClass: 'bg-[#3b82f6] text-brutal-black dark:text-white',\n    },\n    error: {\n        icon: X,\n        colorClass: 'bg-brutal-destructive text-white',\n    },\n}\n\nconst activeConfig = computed(() => statusConfig[props.status] || statusConfig.info)\n</script>\n\n<template>\n    <div\n        :class=\"cn(\n            'flex flex-col items-center justify-center text-center p-8 border-3 border-brutal-black dark:border-white bg-white dark:bg-brutal-black shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] dark:shadow-[6px_6px_0px_0px_rgba(255,255,255,1)]',\n            props.class\n        )\"\n    >\n        <div class=\"mb-6 select-none\">\n            <slot name=\"icon\">\n                <div\n                    :class=\"cn(\n                        'w-16 h-16 rounded-none flex items-center justify-center border-3 border-brutal-black shadow-[3px_3px_0px_0px_rgba(0,0,0,1)]',\n                        activeConfig.colorClass\n                    )\"\n                >\n                    <component \n                        :is=\"activeConfig.icon\" \n                        class=\"w-10 h-10 stroke-[3]\" \n                    />\n                </div>\n            </slot>\n        </div>\n\n        <h2 \n            v-if=\"title || $slots.title\" \n            class=\"text-2xl font-black text-brutal-black dark:text-white mb-2 uppercase tracking-wide\"\n        >\n            <slot name=\"title\">\n                {{ title }}\n            </slot>\n        </h2>\n\n        <p \n            v-if=\"subTitle || $slots.subTitle\" \n            class=\"text-sm font-bold text-gray-500 dark:text-gray-400 max-w-md mb-6 leading-relaxed\"\n        >\n            <slot name=\"subTitle\">\n                {{ subTitle }}\n            </slot>\n        </p>\n\n        <div \n            v-if=\"$slots.extra\" \n            class=\"flex items-center gap-3 mt-2\"\n        >\n            <slot name=\"extra\" />\n        </div>\n    </div>\n</template>\n",
      "type": "registry:ui"
    }
  ],
