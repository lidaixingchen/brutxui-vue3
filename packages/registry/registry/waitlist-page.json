{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "waitlist-page",
  "type": "registry:ui",
  "title": "Waitlist Page",
  "description": "A highly customizable neo-brutalist Waitlist Page component built with Brutx design tokens for Vue 3.",
  "dependencies": [
    "@lucide/vue"
  ],
  "registryDependencies": [
    "button",
    "input"
  ],
  "files": [
    {
      "path": "components/ui/waitlist-page/WaitlistPage.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed, ref } from 'vue'\nimport { Sparkles, Users, Star } from '@lucide/vue'\nimport { useLocale } from '@/composables/useLocale'\nimport { cn } from '@/lib/utils'\nimport Button from '@/components/ui/button/Button.vue'\nimport Input from '@/components/ui/input/Input.vue'\n\ninterface WaitlistPageProps {\n    title?: string\n    description?: string\n    ctaText?: string\n    waitlistCount?: number\n    class?: string\n}\n\nconst props = withDefaults(defineProps<WaitlistPageProps>(), {\n    title: undefined,\n    description: undefined,\n    ctaText: undefined,\n    waitlistCount: 0,\n    class: undefined,\n})\n\nconst { t } = useLocale()\n\nconst resolvedTitle = computed(() => props.title ?? t('waitlistPage.title'))\nconst resolvedDescription = computed(() => props.description ?? t('waitlistPage.defaultDescription'))\nconst resolvedCtaText = computed(() => props.ctaText ?? t('waitlistPage.ctaText'))\n\nconst emit = defineEmits<{\n    submit: [email: string]\n}>()\n\nconst email = ref('')\n\nconst EMAIL_REGEX = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/\n\nconst rootClasses = computed(() => cn('w-full max-w-lg mx-auto text-center', props.class))\n\nfunction handleSubmit() {\n    if (email.value && EMAIL_REGEX.test(email.value)) {\n        emit('submit', email.value)\n    }\n}\n</script>\n\n<template>\n    <div :class=\"rootClasses\">\n        <div class=\"inline-flex items-center gap-2 mb-6 bg-brutal-accent px-3 py-1 border-3 border-brutal rotate-[-1deg]\">\n            <Sparkles class=\"h-4 w-4 stroke-[3] animate-spin\" />\n            <span class=\"font-black text-sm\">{{ t('waitlistPage.earlyAccess') }}</span>\n        </div>\n\n        <h1 class=\"text-3xl font-black tracking-tight\">\n{{ resolvedTitle }}\n</h1>\n        <p v-if=\"resolvedDescription\" class=\"mt-3 text-brutal-muted-foreground font-medium\">\n{{ resolvedDescription }}\n</p>\n\n        <form class=\"mt-8 flex flex-col sm:flex-row gap-3\" @submit.prevent=\"handleSubmit\">\n            <Input v-model=\"email\" type=\"email\" placeholder=\"you@example.com\" class=\"flex-1\" />\n            <Button type=\"submit\" variant=\"primary\">\n{{ resolvedCtaText }}\n</Button>\n        </form>\n\n        <div class=\"mt-8 flex items-center justify-center gap-6 text-sm font-bold text-brutal-muted-foreground\">\n            <div v-if=\"waitlistCount > 0\" class=\"flex items-center gap-1\">\n                <Users class=\"h-4 w-4 stroke-[3]\" />\n                <span>{{ t('waitlistPage.onWaitlist', { count: waitlistCount.toLocaleString() }) }}</span>\n            </div>\n            <div class=\"flex items-center gap-1\">\n                <Star v-for=\"i in 5\" :key=\"i\" class=\"h-3 w-3 fill-brutal-accent text-brutal-accent\" />\n            </div>\n            <div class=\"flex items-center gap-1\">\n                <div class=\"h-2 w-2 rounded-full bg-brutal-success animate-pulse\" />\n                <span>{{ t('waitlistPage.live') }}</span>\n            </div>\n        </div>\n    </div>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "composables/useLocale.ts",
      "content": "import { type ComputedRef, type InjectionKey, type MaybeRef, computed, inject, provide, unref } from 'vue'\nimport { zhCN } from '../locales/zh-CN'\nimport type { Locale } from '../locales/types'\n\nexport const LOCALE_INJECTION_KEY: InjectionKey<MaybeRef<Locale>> = Symbol('brutx-ui-locale')\n\nexport type TranslateFunction = (path: string, params?: Record<string, string | number>) => string\n\nexport function provideLocale(locale: MaybeRef<Locale>) {\n    provide(LOCALE_INJECTION_KEY, locale)\n}\n\nfunction resolveByPath(obj: unknown, path: string): string | undefined {\n    const keys = path.split('.')\n    let result: unknown = obj\n    for (const key of keys) {\n        if (result == null || typeof result !== 'object') return undefined\n        result = (result as Record<string, unknown>)[key]\n    }\n    return typeof result === 'string' ? result : undefined\n}\n\nfunction interpolate(template: string, params?: Record<string, string | number>): string {\n    if (!params) return template\n    return Object.entries(params).reduce(\n        (str, [k, v]) => str.split(`{${k}}`).join(String(v)),\n        template,\n    )\n}\n\nexport function useLocale(): { locale: ComputedRef<Locale>; t: TranslateFunction } {\n    const injected = inject<MaybeRef<Locale> | undefined>(LOCALE_INJECTION_KEY, undefined)\n\n    const locale = computed<Locale>(() => {\n        const resolved = injected ? unref(injected) : undefined\n        return resolved ?? zhCN\n    })\n\n    function t(path: string, params?: Record<string, string | number>): string {\n        const currentVal = resolveByPath(locale.value, path)\n        if (currentVal !== undefined) return interpolate(currentVal, params)\n\n        const fallbackVal = resolveByPath(zhCN, path)\n        if (fallbackVal !== undefined) return interpolate(fallbackVal, params)\n\n        return path\n    }\n\n    return { locale, t }\n}\n",
      "type": "registry:ui"
    }
  ],
  "tailwind": {
