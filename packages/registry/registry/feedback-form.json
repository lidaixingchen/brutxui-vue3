{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "feedback-form",
  "type": "registry:ui",
  "title": "Feedback Form",
  "description": "A highly customizable neo-brutalist Feedback Form component built with Brutx design tokens for Vue 3.",
  "dependencies": [
    "@lucide/vue"
  ],
  "registryDependencies": [
    "card",
    "input",
    "textarea",
    "button"
  ],
  "files": [
    {
      "path": "components/ui/feedback-form/FeedbackForm.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed, ref } from 'vue'\nimport { Send } from '@lucide/vue'\nimport { cn } from '@/lib/utils'\nimport { useLocale } from '@/composables/useLocale'\nimport Card from '@/components/ui/card/Card.vue'\nimport CardContent from '@/components/ui/card/CardContent.vue'\nimport Input from '@/components/ui/input/Input.vue'\nimport Textarea from '@/components/ui/textarea/Textarea.vue'\nimport Button from '@/components/ui/button/Button.vue'\n\ninterface FeedbackFormProps {\n    title?: string\n    description?: string\n    submitText?: string\n    class?: string\n}\n\nconst props = withDefaults(defineProps<FeedbackFormProps>(), {\n    title: undefined,\n    description: undefined,\n    submitText: undefined,\n    class: undefined,\n})\n\nconst emit = defineEmits<{\n    submit: [payload: { name: string; email: string; subject: string; message: string }]\n}>()\n\nconst { t } = useLocale()\n\nconst resolvedTitle = computed(() => props.title ?? t('feedbackForm.defaultTitle'))\nconst resolvedDescription = computed(() => props.description ?? t('feedbackForm.defaultDescription'))\nconst resolvedSubmitText = computed(() => props.submitText ?? t('feedbackForm.defaultSubmitText'))\nconst nameLabel = computed(() => t('feedbackForm.nameLabel'))\nconst emailLabel = computed(() => t('feedbackForm.emailLabel'))\nconst subjectLabel = computed(() => t('feedbackForm.subjectLabel'))\nconst messageLabel = computed(() => t('feedbackForm.messageLabel'))\n\nconst name = ref('')\nconst email = ref('')\nconst subject = ref('')\nconst message = ref('')\n\nconst rootClasses = computed(() => cn('w-full max-w-2xl mx-auto', props.class))\n\nfunction handleSubmit() {\n    emit('submit', {\n        name: name.value,\n        email: email.value,\n        subject: subject.value,\n        message: message.value,\n    })\n}\n</script>\n\n<template>\n    <div :class=\"rootClasses\">\n        <slot name=\"header\">\n            <div class=\"text-center mb-8\">\n                <h2 class=\"text-3xl font-black tracking-tight\">\n                    {{ resolvedTitle }}\n                </h2>\n                <p v-if=\"resolvedDescription\" class=\"mt-2 text-brutal-muted-foreground font-medium\">\n                    {{ resolvedDescription }}\n                </p>\n            </div>\n        </slot>\n\n        <slot>\n            <Card variant=\"default\">\n                <CardContent class=\"pt-6\">\n                    <form class=\"space-y-4\" @submit.prevent=\"handleSubmit\">\n                        <div class=\"space-y-2\">\n                            <label class=\"text-sm font-bold text-brutal-fg\">\n                                {{ nameLabel }}\n                            </label>\n                            <Input v-model=\"name\" :placeholder=\"nameLabel\" />\n                        </div>\n                        <div class=\"space-y-2\">\n                            <label class=\"text-sm font-bold text-brutal-fg\">\n                                {{ emailLabel }}\n                            </label>\n                            <Input v-model=\"email\" type=\"email\" :placeholder=\"emailLabel\" />\n                        </div>\n                        <div class=\"space-y-2\">\n                            <label class=\"text-sm font-bold text-brutal-fg\">\n                                {{ subjectLabel }}\n                            </label>\n                            <Input v-model=\"subject\" :placeholder=\"subjectLabel\" />\n                        </div>\n                        <div class=\"space-y-2\">\n                            <label class=\"text-sm font-bold text-brutal-fg\">\n                                {{ messageLabel }}\n                            </label>\n                            <Textarea v-model=\"message\" :placeholder=\"messageLabel\" />\n                        </div>\n                        <Button variant=\"primary\" type=\"submit\" class=\"w-full\">\n                            <Send class=\"h-4 w-4 mr-2\" />\n                            {{ resolvedSubmitText }}\n                        </Button>\n                    </form>\n                </CardContent>\n            </Card>\n        </slot>\n\n        <slot name=\"footer\" />\n    </div>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "composables/useLocale.ts",
      "content": "import { type ComputedRef, type InjectionKey, type MaybeRef, computed, inject, provide, unref } from 'vue'\nimport { zhCN } from '../locales/zh-CN'\nimport type { Locale } from '../locales/types'\n\nexport const LOCALE_INJECTION_KEY: InjectionKey<MaybeRef<Locale>> = Symbol('brutx-ui-locale')\n\nexport type TranslateFunction = (path: string, params?: Record<string, string | number>) => string\n\nexport function provideLocale(locale: MaybeRef<Locale>) {\n    provide(LOCALE_INJECTION_KEY, locale)\n}\n\nfunction resolveByPath(obj: unknown, path: string): string | undefined {\n    const keys = path.split('.')\n    let result: unknown = obj\n    for (const key of keys) {\n        if (result == null || typeof result !== 'object') return undefined\n        result = (result as Record<string, unknown>)[key]\n    }\n    return typeof result === 'string' ? result : undefined\n}\n\nfunction interpolate(template: string, params?: Record<string, string | number>): string {\n    if (!params) return template\n    return Object.entries(params).reduce(\n        (str, [k, v]) => str.split(`{${k}}`).join(String(v)),\n        template,\n    )\n}\n\nexport function useLocale(): { locale: ComputedRef<Locale>; t: TranslateFunction } {\n    const injected = inject<MaybeRef<Locale> | undefined>(LOCALE_INJECTION_KEY, undefined)\n\n    const locale = computed<Locale>(() => {\n        const resolved = injected ? unref(injected) : undefined\n        return resolved ?? zhCN\n    })\n\n    function t(path: string, params?: Record<string, string | number>): string {\n        const currentVal = resolveByPath(locale.value, path)\n        if (currentVal !== undefined) return interpolate(currentVal, params)\n\n        const fallbackVal = resolveByPath(zhCN, path)\n        if (fallbackVal !== undefined) return interpolate(fallbackVal, params)\n\n        return path\n    }\n\n    return { locale, t }\n}\n",
      "type": "registry:ui"
    }
  ],
  "tailwind": {
