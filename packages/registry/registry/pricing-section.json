{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "pricing-section",
  "type": "registry:ui",
  "title": "Pricing Section",
  "description": "Pricing table with plan comparison and feature highlights.",
  "category": "marketing",
