      "brutal-bg": "#ffffff",
      "brutal-fg": "#000000",
      "brutal-primary": "#FF6B6B",
      "brutal-secondary": "#4ECDC4",
      "brutal-accent": "#FFE66D",
      "brutal-destructive": "#EF476F",
      "brutal-success": "#7FB069",
      "brutal-muted": "#f3f4f6",
      "brutal-ring": "#000000",
