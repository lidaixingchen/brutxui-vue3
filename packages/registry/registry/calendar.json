{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "calendar",
  "type": "registry:ui",
  "title": "Calendar",
  "description": "Date calendar with single and range selection powered by v-calendar.",
  "dependencies": [
    "v-calendar",
    "@lucide/vue"
  ],
