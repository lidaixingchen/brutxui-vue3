{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "error-card",
  "type": "registry:ui",
  "title": "Error Card",
  "description": "A highly customizable neo-brutalist Error Card component built with Brutx design tokens for Vue 3.",
  "dependencies": [
    "lucide-vue-next"
  ],
  "registryDependencies": [
    "card",
    "button",
    "alert"
  ],
  "files": [
    {
      "path": "components/ui/error-card/ErrorCard.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { AlertTriangle, RotateCw, X } from 'lucide-vue-next'\nimport { cn } from '@/lib/utils'\nimport { useLocale } from '@/composables/useLocale'\nimport Card from '@/components/ui/card/Card.vue'\nimport CardContent from '@/components/ui/card/CardContent.vue'\nimport Button from '@/components/ui/button/Button.vue'\nimport Alert from '@/components/ui/alert/Alert.vue'\nimport AlertTitle from '@/components/ui/alert/AlertTitle.vue'\nimport AlertDescription from '@/components/ui/alert/AlertDescription.vue'\n\ninterface ErrorCardProps {\n    title?: string\n    description?: string\n    retryText?: string\n    class?: string\n}\n\nconst props = withDefaults(defineProps<ErrorCardProps>(), {\n    title: undefined,\n    description: undefined,\n    retryText: undefined,\n    class: '',\n})\n\nconst { t } = useLocale()\n\nconst emit = defineEmits<{\n    retry: []\n    dismiss: []\n}>()\n\nconst rootClasses = computed(() => cn('w-full max-w-md', props.class))\n\nconst resolvedTitle = computed(() => props.title ?? t('errorCard.defaultTitle'))\nconst resolvedDescription = computed(() => props.description ?? t('errorCard.defaultDescription'))\nconst resolvedRetryText = computed(() => props.retryText ?? t('errorCard.defaultRetryText'))\n</script>\n\n<template>\n    <Card :class=\"rootClasses\" variant=\"default\">\n        <Alert variant=\"danger\" class=\"mb-4\">\n            <AlertTriangle class=\"h-5 w-5\" />\n            <AlertTitle>{{ resolvedTitle }}</AlertTitle>\n            <AlertDescription>{{ resolvedDescription }}</AlertDescription>\n        </Alert>\n        <CardContent>\n            <div class=\"flex items-center justify-end gap-3\">\n                <Button variant=\"ghost\" size=\"sm\" @click=\"emit('dismiss')\">\n                    <X class=\"mr-1 h-4 w-4 stroke-[3]\" />\n                    {{ t('errorCard.dismiss') }}\n                </Button>\n                <Button variant=\"primary\" size=\"sm\" @click=\"emit('retry')\">\n                    <RotateCw class=\"mr-1 h-4 w-4 stroke-[3]\" />\n                    {{ resolvedRetryText }}\n                </Button>\n            </div>\n            <slot name=\"actions\" />\n        </CardContent>\n    </Card>\n</template>\n",
      "type": "registry:ui"
    }
  ],
  "tailwind": {
    "config": {
      "theme": {
        "extend": {
          "borderWidth": {
            "3": "var(--brutal-border-width, 3px)"
          },
          "borderColor": {
            "brutal": "var(--brutal-border-color, #000000)"
          },
          "borderRadius": {
            "brutal": "var(--brutal-radius, 0px)"
          },
          "colors": {
            "brutal-bg": "var(--brutal-bg, #ffffff)",
            "brutal-fg": "var(--brutal-fg, #000000)",
            "brutal-primary": "var(--brutal-primary, #FF6B6B)",
            "brutal-secondary": "var(--brutal-secondary, #4ECDC4)",
            "brutal-accent": "var(--brutal-accent, #FFE66D)",
            "brutal-destructive": "var(--brutal-destructive, #EF476F)",
            "brutal-success": "var(--brutal-success, #7FB069)",
            "brutal-muted": "var(--brutal-muted, #f3f4f6)",
            "brutal-ring": "var(--brutal-ring, #000000)",
            "brutal-info": "var(--brutal-info, #4A90D9)",
            "brutal-muted-foreground": "var(--brutal-muted-foreground, #4B5563)",
            "brutal-overlay": "var(--brutal-overlay, rgba(0, 0, 0, 0.5))",
            "brutal-placeholder": "var(--brutal-placeholder, #9CA3AF)"
          },
          "boxShadow": {
            "brutal": "var(--brutal-shadow-offset-x, 4px) var(--brutal-shadow-offset-y, 4px) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-sm": "calc(var(--brutal-shadow-offset-x, 4px) / 2) calc(var(--brutal-shadow-offset-y, 4px) / 2) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-lg": "calc(var(--brutal-shadow-offset-x, 4px) * 1.5) calc(var(--brutal-shadow-offset-y, 4px) * 1.5) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-xl": "calc(var(--brutal-shadow-offset-x, 4px) * 2) calc(var(--brutal-shadow-offset-y, 4px) * 2) 0px 0px var(--brutal-shadow-color, #000000)"
          }
        }
      }
    }
  },
  "cssVars": {
    "light": {
      "brutal-border-width": "3px",
      "brutal-border-color": "#000000",
      "brutal-shadow-offset-x": "4px",
      "brutal-shadow-offset-y": "4px",
      "brutal-shadow-color": "#000000",
      "brutal-radius": "0px",
      "brutal-pressed-offset": "2px",
      "brutal-bg": "#ffffff",
      "brutal-fg": "#000000",
      "brutal-primary": "#FF6B6B",
      "brutal-secondary": "#4ECDC4",
      "brutal-accent": "#FFE66D",
      "brutal-destructive": "#EF476F",
      "brutal-success": "#7FB069",
      "brutal-muted": "#f3f4f6",
      "brutal-ring": "#000000",
      "brutal-info": "#4A90D9",
      "brutal-muted-foreground": "#4B5563",
      "brutal-overlay": "rgba(0, 0, 0, 0.5)",
      "brutal-placeholder": "#9CA3AF"
    },
    "dark": {
      "brutal-border-width": "3px",
      "brutal-border-color": "#ffffff",
      "brutal-shadow-offset-x": "4px",
      "brutal-shadow-offset-y": "4px",
      "brutal-shadow-color": "#ffffff",
      "brutal-radius": "0px",
      "brutal-pressed-offset": "2px",
      "brutal-bg": "#141414",
      "brutal-fg": "#ffffff",
      "brutal-primary": "#FF6B6B",
      "brutal-secondary": "#4ECDC4",
      "brutal-accent": "#FFE66D",
      "brutal-destructive": "#EF476F",
      "brutal-success": "#7FB069",
      "brutal-muted": "#1e1e1e",
      "brutal-ring": "#ffffff",
      "brutal-info": "#3B82F6",
      "brutal-muted-foreground": "#9CA3AF",
      "brutal-overlay": "rgba(0, 0, 0, 0.7)",
      "brutal-placeholder": "#6B7280"
    }
  }
}