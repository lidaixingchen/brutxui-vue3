{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "loading-page",
  "type": "registry:ui",
  "title": "Loading Page",
  "description": "A highly customizable neo-brutalist Loading Page component built with Brutx design tokens for Vue 3.",
  "dependencies": [
    "@lucide/vue"
  ],
  "registryDependencies": [
    "skeleton",
    "spinner",
    "progress"
  ],
  "files": [
    {
      "path": "components/ui/loading-page/LoadingPage.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { useLocale } from '@/composables/useLocale'\nimport { cn } from '@/lib/utils'\nimport Skeleton from '@/components/ui/skeleton/Skeleton.vue'\nimport Spinner from '@/components/ui/spinner/Spinner.vue'\nimport Progress from '@/components/ui/progress/Progress.vue'\n\ninterface LoadingPageProps {\n    title?: string\n    description?: string\n    progress?: number\n    class?: string\n}\n\nconst props = withDefaults(defineProps<LoadingPageProps>(), {\n    title: undefined,\n    description: undefined,\n    progress: undefined,\n    class: undefined,\n})\n\nconst { t } = useLocale()\n\nconst resolvedTitle = computed(() => props.title ?? t('loadingPage.defaultTitle'))\nconst resolvedDescription = computed(() => props.description ?? t('loadingPage.defaultDescription'))\n\nconst hasProgress = computed(() => props.progress !== undefined)\n\nconst rootClasses = computed(() =>\n    cn('min-h-screen flex items-center justify-center bg-brutal-bg p-4', props.class)\n)\n</script>\n\n<template>\n    <div :class=\"rootClasses\">\n        <div class=\"w-full max-w-lg text-center relative\">\n            <slot name=\"header\" />\n\n            <div class=\"relative border-3 border-brutal bg-brutal-bg shadow-brutal p-8 sm:p-12\">\n                <Skeleton variant=\"accent\" class=\"absolute -top-3 -left-3 h-6 w-24\" />\n                <Skeleton variant=\"secondary\" class=\"absolute -bottom-3 -right-3 h-6 w-32\" />\n\n                <div class=\"flex justify-center mb-6\">\n                    <Spinner size=\"lg\" variant=\"primary\" />\n                </div>\n\n                <h1 class=\"text-2xl sm:text-3xl font-black tracking-tight text-brutal-fg\">\n                    {{ resolvedTitle }}\n                </h1>\n\n                <p class=\"mt-3 text-brutal-muted-foreground font-medium\">\n                    {{ resolvedDescription }}\n                </p>\n\n                <slot />\n\n                <div v-if=\"hasProgress\" class=\"mt-6\">\n                    <Progress :model-value=\"progress\" />\n                </div>\n\n                <slot name=\"footer\" />\n            </div>\n        </div>\n    </div>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "composables/useLocale.ts",
      "content": "import { type ComputedRef, type InjectionKey, type MaybeRef, computed, inject, provide, unref } from 'vue'\nimport { zhCN } from '../locales/zh-CN'\nimport type { Locale } from '../locales/types'\n\nexport const LOCALE_INJECTION_KEY: InjectionKey<MaybeRef<Locale>> = Symbol('brutx-ui-locale')\n\nexport type TranslateFunction = (path: string, params?: Record<string, string | number>) => string\n\nexport function provideLocale(locale: MaybeRef<Locale>) {\n    provide(LOCALE_INJECTION_KEY, locale)\n}\n\nfunction resolveByPath(obj: unknown, path: string): string | undefined {\n    const keys = path.split('.')\n    let result: unknown = obj\n    for (const key of keys) {\n        if (result == null || typeof result !== 'object') return undefined\n        result = (result as Record<string, unknown>)[key]\n    }\n    return typeof result === 'string' ? result : undefined\n}\n\nfunction interpolate(template: string, params?: Record<string, string | number>): string {\n    if (!params) return template\n    return Object.entries(params).reduce(\n        (str, [k, v]) => str.split(`{${k}}`).join(String(v)),\n        template,\n    )\n}\n\nexport function useLocale(): { locale: ComputedRef<Locale>; t: TranslateFunction } {\n    const injected = inject<MaybeRef<Locale> | undefined>(LOCALE_INJECTION_KEY, undefined)\n\n    const locale = computed<Locale>(() => {\n        const resolved = injected ? unref(injected) : undefined\n        return resolved ?? zhCN\n    })\n\n    function t(path: string, params?: Record<string, string | number>): string {\n        const currentVal = resolveByPath(locale.value, path)\n        if (currentVal !== undefined) return interpolate(currentVal, params)\n\n        const fallbackVal = resolveByPath(zhCN, path)\n        if (fallbackVal !== undefined) return interpolate(fallbackVal, params)\n\n        return path\n    }\n\n    return { locale, t }\n}\n",
      "type": "registry:ui"
    }
  ],
