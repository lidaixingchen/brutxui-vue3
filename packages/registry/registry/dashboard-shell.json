{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "dashboard-shell",
  "type": "registry:ui",
  "title": "Dashboard Shell",
  "description": "A highly customizable neo-brutalist Dashboard Shell component built with Brutx design tokens for Vue 3.",
  "dependencies": [
    "lucide-vue-next"
  ],
  "registryDependencies": [],
  "files": [
    {
      "path": "components/ui/dashboard-shell/DashboardShell.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed, ref } from 'vue'\nimport { Menu } from 'lucide-vue-next'\nimport { cn } from '@/lib/utils'\n\ninterface DashboardShellProps {\n    userEmail?: string\n    class?: string\n}\n\nconst props = withDefaults(defineProps<DashboardShellProps>(), {\n    userEmail: 'user@example.com',\n    class: '',\n})\n\nconst emit = defineEmits<{\n    signOut: []\n}>()\n\nconst sidebarOpen = ref(true)\n\nconst rootClasses = computed(() => cn('flex h-screen bg-brutal-bg', props.class))\n\nconst sidebarClasses = computed(() =>\n    cn(\n        'border-r-3 border-brutal bg-brutal-bg p-4 flex flex-col',\n        sidebarOpen.value ? 'w-64' : 'w-0 overflow-hidden md:w-64'\n    )\n)\n</script>\n\n<template>\n    <div :class=\"rootClasses\">\n        <aside :class=\"sidebarClasses\" aria-label=\"Sidebar navigation\">\n            <div class=\"font-black text-lg tracking-tight mb-8\">\nBrutxUI\n</div>\n            <nav class=\"flex-1 space-y-1\">\n                <slot name=\"sidebar\" />\n            </nav>\n            <div class=\"border-t-3 border-brutal pt-4 mt-4\">\n                <div class=\"text-sm font-bold truncate\">\n{{ userEmail }}\n</div>\n                <button class=\"text-sm font-bold text-brutal-destructive mt-1\" @click=\"emit('signOut')\">\nSign out\n</button>\n            </div>\n        </aside>\n\n        <div class=\"flex-1 flex flex-col overflow-hidden\">\n            <header class=\"border-b-3 border-brutal bg-brutal-bg px-6 py-3 flex items-center justify-between\">\n                <button class=\"md:hidden h-8 w-8 flex items-center justify-center border-3 border-brutal shadow-brutal-sm\" @click=\"sidebarOpen = !sidebarOpen\">\n                    <Menu class=\"h-4 w-4 stroke-[3]\" />\n                </button>\n                <slot name=\"header\" />\n            </header>\n\n            <main class=\"flex-1 overflow-y-auto p-6\">\n                <slot />\n            </main>\n        </div>\n    </div>\n</template>\n",
      "type": "registry:ui"
    }
  ],
  "tailwind": {
    "config": {
      "theme": {
        "extend": {
          "borderWidth": {
            "3": "var(--brutal-border-width, 3px)"
          },
          "borderColor": {
            "brutal": "var(--brutal-border-color, #000000)"
          },
          "borderRadius": {
            "brutal": "var(--brutal-radius, 0px)"
          },
          "colors": {
            "brutal-bg": "var(--brutal-bg, #ffffff)",
            "brutal-fg": "var(--brutal-fg, #000000)",
            "brutal-primary": "var(--brutal-primary, #FF6B6B)",
            "brutal-secondary": "var(--brutal-secondary, #4ECDC4)",
            "brutal-accent": "var(--brutal-accent, #FFE66D)",
            "brutal-destructive": "var(--brutal-destructive, #EF476F)",
            "brutal-success": "var(--brutal-success, #7FB069)",
            "brutal-muted": "var(--brutal-muted, #f3f4f6)",
            "brutal-ring": "var(--brutal-ring, #000000)",
            "brutal-info": "var(--brutal-info, #4A90D9)",
            "brutal-muted-foreground": "var(--brutal-muted-foreground, #4B5563)",
            "brutal-overlay": "var(--brutal-overlay, rgba(0, 0, 0, 0.5))",
            "brutal-placeholder": "var(--brutal-placeholder, #9CA3AF)"
          },
          "boxShadow": {
            "brutal": "var(--brutal-shadow-offset-x, 4px) var(--brutal-shadow-offset-y, 4px) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-sm": "calc(var(--brutal-shadow-offset-x, 4px) / 2) calc(var(--brutal-shadow-offset-y, 4px) / 2) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-lg": "calc(var(--brutal-shadow-offset-x, 4px) * 1.5) calc(var(--brutal-shadow-offset-y, 4px) * 1.5) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-xl": "calc(var(--brutal-shadow-offset-x, 4px) * 2) calc(var(--brutal-shadow-offset-y, 4px) * 2) 0px 0px var(--brutal-shadow-color, #000000)"
          }
        }
      }
    }
  },
