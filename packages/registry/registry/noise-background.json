{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "noise-background",
  "type": "registry:ui",
  "title": "Noise Background",
  "description": "A highly customizable neo-brutalist Noise Background component built with Brutx design tokens for Vue 3.",
  "dependencies": [],
  "registryDependencies": [],
  "files": [
    {
      "path": "components/ui/noise-background/NoiseBackground.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed, ref, watch, onMounted, onUnmounted, useId } from 'vue'\nimport { type VariantProps } from 'class-variance-authority'\nimport { cn } from '@/lib/utils'\nimport { noiseBackgroundVariants } from '@/components/ui/noise-background/noise-background-variants'\n\ntype NoiseBackgroundVariantProps = VariantProps<typeof noiseBackgroundVariants>\n\ninterface NoiseBackgroundProps {\n    /** 噪点类型 */\n    type?: 'fractalNoise' | 'turbulence'\n    /** 噪点频率 */\n    frequency?: number\n    /** 噪点层数 */\n    octaves?: number\n    /** 不透明度 */\n    opacity?: number\n    /** 是否启用动画 */\n    animated?: boolean\n    /** 动画速度（秒） */\n    animationDuration?: number\n    /** 圆角 */\n    rounded?: NonNullable<NoiseBackgroundVariantProps['rounded']>\n    /** 自定义类名 */\n    class?: string\n}\n\nconst props = withDefaults(defineProps<NoiseBackgroundProps>(), {\n    type: 'fractalNoise',\n    frequency: 0.65,\n    octaves: 3,\n    opacity: 0.5,\n    animated: false,\n    animationDuration: 8,\n    rounded: 'none',\n    class: undefined,\n})\n\n// 使用 Vue ref 替代直接 DOM 访问\nconst turbulenceRef = ref<SVGFETurbulenceElement | null>(null)\n\n// 使用 useId 生成 SSR 安全且稳定的唯一 ID\nconst filterId = `noise-${useId()}`\n\n// 动画相关\nlet animationFrame: number | null = null\nconst currentFrequency = ref(props.frequency)\n\nfunction startAnimation() {\n    // SSR 兼容性检查\n    if (!props.animated || typeof window === 'undefined' || props.animationDuration <= 0) return\n\n    stopAnimation()\n\n    const startTime = performance.now()\n    const baseFrequency = props.frequency\n    const frequencyRange = 0.1\n\n    function step(currentTime: number) {\n        const elapsed = (currentTime - startTime) / 1000\n        const progress = (elapsed % props.animationDuration) / props.animationDuration\n        currentFrequency.value = baseFrequency + Math.sin(progress * Math.PI * 2) * frequencyRange\n\n        // 使用 Vue ref 更新 SVG 滤镜属性\n        if (turbulenceRef.value) {\n            turbulenceRef.value.setAttribute('baseFrequency', currentFrequency.value.toString())\n        }\n\n        animationFrame = requestAnimationFrame(step)\n    }\n\n    animationFrame = requestAnimationFrame(step)\n}\n\nfunction stopAnimation() {\n    if (animationFrame) {\n        cancelAnimationFrame(animationFrame)\n        animationFrame = null\n    }\n}\n\n// 响应 animated 属性变化\nwatch(() => props.animated, (newVal) => {\n    if (newVal) {\n        startAnimation()\n    } else {\n        stopAnimation()\n    }\n})\n\n// 响应 frequency 和 animationDuration 属性变化\nwatch(() => [props.frequency, props.animationDuration], () => {\n    if (props.animated) {\n        startAnimation()\n    }\n})\n\nonMounted(() => {\n    if (props.animated) {\n        startAnimation()\n    }\n})\n\nonUnmounted(() => {\n    stopAnimation()\n})\n\nconst classes = computed(() =>\n    cn(noiseBackgroundVariants({ rounded: props.rounded }), props.class)\n)\n</script>\n\n<template>\n    <div :class=\"classes\">\n        <svg\n            class=\"absolute inset-0 w-full h-full pointer-events-none\"\n            aria-hidden=\"true\"\n        >\n            <filter :id=\"filterId\">\n                <feTurbulence\n                    ref=\"turbulenceRef\"\n                    :type=\"type\"\n                    :baseFrequency=\"frequency\"\n                    :numOctaves=\"octaves\"\n                    stitchTiles=\"stitch\"\n                />\n            </filter>\n            <rect\n                width=\"100%\"\n                height=\"100%\"\n                :filter=\"`url(#${filterId})`\"\n                :opacity=\"opacity\"\n            />\n        </svg>\n        <div class=\"relative z-10\">\n            <slot />\n        </div>\n    </div>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/noise-background/noise-background-variants.ts",
      "content": "import { cva } from 'class-variance-authority'\n\nexport const noiseBackgroundVariants = cva(\n    [\n        'relative overflow-hidden',\n    ],\n    {\n        variants: {\n            rounded: {\n                none: 'rounded-none',\n                default: 'rounded-brutal',\n                lg: 'rounded-brutal-lg',\n                full: 'rounded-full',\n            },\n        },\n        defaultVariants: {\n            rounded: 'none',\n        },\n    }\n)\n",
      "type": "registry:ui"
    }
  ],
  "tailwind": {
