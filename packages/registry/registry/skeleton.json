{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "skeleton",
  "type": "registry:ui",
  "title": "Skeleton",
  "description": "A highly customizable neo-brutalist Skeleton component built with Brutx design tokens for Vue 3.",
  "dependencies": [],
  "registryDependencies": [],
  "files": [
    {
      "path": "components/ui/skeleton/Skeleton.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { type VariantProps } from 'class-variance-authority'\nimport { cn } from '@/lib/utils'\nimport { skeletonVariants } from '@/components/ui/skeleton/skeleton-variants'\n\ntype SkeletonVariantProps = VariantProps<typeof skeletonVariants>\n\ninterface SkeletonProps {\n    variant?: NonNullable<SkeletonVariantProps['variant']>\n    class?: string\n}\n\nconst props = withDefaults(defineProps<SkeletonProps>(), {\n    variant: 'default',\n    class: '',\n})\n\nconst classes = computed(() =>\n    cn(skeletonVariants({ variant: props.variant }), props.class)\n)\n</script>\n\n<template>\n    <div :class=\"classes\">\n        <slot />\n    </div>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/skeleton/SkeletonAvatar.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { type VariantProps } from 'class-variance-authority'\nimport { cn } from '@/lib/utils'\nimport { skeletonVariants } from '@/components/ui/skeleton/skeleton-variants'\nimport Skeleton from '@/components/ui/skeleton/Skeleton.vue'\n\ntype SkeletonVariantProps = VariantProps<typeof skeletonVariants>\n\ninterface SkeletonAvatarProps {\n    variant?: NonNullable<SkeletonVariantProps['variant']>\n    size?: 'sm' | 'default' | 'lg' | 'xl'\n    class?: string\n}\n\nconst props = withDefaults(defineProps<SkeletonAvatarProps>(), {\n    variant: 'default',\n    size: 'default',\n    class: '',\n})\n\nconst sizeClasses: Record<string, string> = {\n    sm: 'h-8 w-8',\n    default: 'h-10 w-10',\n    lg: 'h-12 w-12',\n    xl: 'h-16 w-16',\n}\n\nconst classes = computed(() => cn(sizeClasses[props.size], props.class))\n</script>\n\n<template>\n    <Skeleton :variant=\"variant\" :class=\"classes\" />\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/skeleton/SkeletonCard.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { type VariantProps } from 'class-variance-authority'\nimport { cn } from '@/lib/utils'\nimport { skeletonVariants } from '@/components/ui/skeleton/skeleton-variants'\nimport Skeleton from '@/components/ui/skeleton/Skeleton.vue'\nimport SkeletonText from '@/components/ui/skeleton/SkeletonText.vue'\n\ntype SkeletonVariantProps = VariantProps<typeof skeletonVariants>\n\ninterface SkeletonCardProps {\n    variant?: NonNullable<SkeletonVariantProps['variant']>\n    class?: string\n}\n\nconst props = withDefaults(defineProps<SkeletonCardProps>(), {\n    variant: 'default',\n    class: '',\n})\n\nconst classes = computed(() =>\n    cn('p-4 border-3 border-brutal shadow-brutal bg-brutal-bg', props.class)\n)\n</script>\n\n<template>\n    <div :class=\"classes\">\n        <div class=\"space-y-4\">\n            <Skeleton :variant=\"variant\" class=\"h-32 w-full\" />\n            <Skeleton :variant=\"variant\" class=\"h-6 w-3/4\" />\n            <SkeletonText :variant=\"variant\" :lines=\"2\" />\n            <div class=\"flex gap-2\">\n                <Skeleton :variant=\"variant\" class=\"h-10 w-24\" />\n                <Skeleton :variant=\"variant\" class=\"h-10 w-24\" />\n            </div>\n        </div>\n    </div>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/skeleton/SkeletonTable.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { type VariantProps } from 'class-variance-authority'\nimport { cn } from '@/lib/utils'\nimport { skeletonVariants } from '@/components/ui/skeleton/skeleton-variants'\nimport Skeleton from '@/components/ui/skeleton/Skeleton.vue'\n\ntype SkeletonVariantProps = VariantProps<typeof skeletonVariants>\n\ninterface SkeletonTableProps {\n    variant?: NonNullable<SkeletonVariantProps['variant']>\n    rows?: number\n    columns?: number\n    class?: string\n}\n\nconst props = withDefaults(defineProps<SkeletonTableProps>(), {\n    variant: 'default',\n    rows: 5,\n    columns: 4,\n    class: '',\n})\n\nconst cellWidths = [0.85, 0.7, 0.9, 0.65]\n\nconst containerClasses = computed(() =>\n    cn('border-3 border-brutal overflow-hidden', props.class)\n)\n\nconst headerCellClasses = computed(() =>\n    Array.from({ length: props.columns }, (_, i) =>\n        cn('flex-1 p-3', i < props.columns - 1 && 'border-r-3 border-brutal')\n    )\n)\n\nconst rowClasses = computed(() =>\n    Array.from({ length: props.rows }, (_, i) =>\n        cn('flex', i < props.rows - 1 && 'border-b-3 border-brutal', i % 2 === 0 && 'bg-brutal-muted')\n    )\n)\n\nconst cellClasses = computed(() =>\n    Array.from({ length: props.columns }, (_, i) =>\n        cn('flex-1 p-3', i < props.columns - 1 && 'border-r-3 border-brutal')\n    )\n)\n</script>\n\n<template>\n    <div :class=\"containerClasses\">\n        <div class=\"flex bg-brutal-accent border-b-3 border-brutal\">\n            <div\n                v-for=\"(headerClass, colIndex) in headerCellClasses\"\n                :key=\"`header-${colIndex}`\"\n                :class=\"headerClass\"\n            >\n                <Skeleton :variant=\"variant\" class=\"h-5 w-3/4 bg-brutal-fg/20\" />\n            </div>\n        </div>\n        <div\n            v-for=\"(rowClass, rowIndex) in rowClasses\"\n            :key=\"`row-${rowIndex}`\"\n            :class=\"rowClass\"\n        >\n            <div\n                v-for=\"(cellClass, colIndex) in cellClasses\"\n                :key=\"`cell-${rowIndex}-${colIndex}`\"\n                :class=\"cellClass\"\n            >\n                <Skeleton\n                    :variant=\"variant\"\n                    class=\"h-4\"\n                    :style=\"{ width: `${(cellWidths[colIndex % cellWidths.length] ?? 0.75) * 100}%` }\"\n                />\n            </div>\n        </div>\n    </div>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/skeleton/SkeletonText.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { type VariantProps } from 'class-variance-authority'\nimport { cn } from '@/lib/utils'\nimport { skeletonVariants } from '@/components/ui/skeleton/skeleton-variants'\nimport Skeleton from '@/components/ui/skeleton/Skeleton.vue'\n\ntype SkeletonVariantProps = VariantProps<typeof skeletonVariants>\n\ninterface SkeletonTextProps {\n    variant?: NonNullable<SkeletonVariantProps['variant']>\n    lines?: number\n    lastLineWidth?: string\n    class?: string\n}\n\nconst props = withDefaults(defineProps<SkeletonTextProps>(), {\n    variant: 'default',\n    lines: 3,\n    lastLineWidth: '60%',\n    class: '',\n})\n\nconst classes = computed(() => cn('space-y-2', props.class))\n</script>\n\n<template>\n    <div :class=\"classes\">\n        <Skeleton\n            v-for=\"index in props.lines\"\n            :key=\"index\"\n            :variant=\"variant\"\n            class=\"h-4\"\n            :style=\"{ width: index === props.lines ? props.lastLineWidth : '100%' }\"\n        />\n    </div>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/skeleton/skeleton-variants.ts",
      "content": "import { cva } from 'class-variance-authority'\n\nexport const skeletonVariants = cva(\n    ['animate-pulse', 'border-3 border-brutal'],\n    {\n        variants: {\n            variant: {\n                default: 'bg-brutal-muted',\n                primary: 'bg-brutal-primary/30',\n                secondary: 'bg-brutal-secondary/30',\n                accent: 'bg-brutal-accent/30',\n            },\n        },\n        defaultVariants: {\n            variant: 'default',\n        },\n    }\n)\n",
      "type": "registry:ui"
    }
  ],
  "tailwind": {
