{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "kbd",
  "type": "registry:ui",
  "title": "Kbd",
  "description": "A highly customizable neo-brutalist Kbd component built with Brutx design tokens for Vue 3.",
  "dependencies": [],
  "registryDependencies": [],
  "files": [
    {
      "path": "components/ui/kbd/Kbd.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue';\nimport { type VariantProps } from 'class-variance-authority';\nimport { cn } from '@/lib/utils';\nimport { kbdVariants } from '@/components/ui/kbd/kbd-variants';\n\ntype KbdVariantProps = VariantProps<typeof kbdVariants>;\n\ninterface KbdProps {\n    size?: NonNullable<KbdVariantProps['size']>;\n    class?: string;\n}\n\nconst props = withDefaults(defineProps<KbdProps>(), {\n    size: 'md',\n});\n\nconst classes = computed(() =>\n    cn(kbdVariants({ size: props.size }), props.class)\n);\n</script>\n\n<template>\n    <kbd :class=\"classes\">\n        <slot />\n    </kbd>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/kbd/kbd-variants.ts",
      "content": "import { cva } from 'class-variance-authority';\n\nexport const kbdVariants = cva(\n    [\n        'inline-flex items-center justify-center',\n        'font-mono font-black text-brutal-fg',\n        'border-3 border-brutal rounded-brutal',\n        'bg-brutal-muted shadow-brutal-sm',\n        'select-none whitespace-nowrap',\n    ].join(' '),\n    {\n        variants: {\n            size: {\n                sm: 'px-1.5 py-0.5 text-xs min-w-[1.25rem]',\n                md: 'px-2 py-1 text-sm min-w-[1.75rem]',\n                lg: 'px-3 py-1.5 text-base min-w-[2.25rem]',\n            },\n        },\n        defaultVariants: {\n            size: 'md',\n        },\n    }\n);\n",
      "type": "registry:ui"
    }
  ],
  "tailwind": {
    "config": {
      "theme": {
        "extend": {
          "borderWidth": {
            "3": "var(--brutal-border-width, 3px)"
          },
          "borderColor": {
            "brutal": "var(--brutal-border-color, #000000)"
          },
          "borderRadius": {
            "brutal": "var(--brutal-radius, 0px)"
          },
          "colors": {
            "brutal-bg": "var(--brutal-bg, #ffffff)",
            "brutal-fg": "var(--brutal-fg, #000000)",
            "brutal-primary": "var(--brutal-primary, #FF6B6B)",
            "brutal-secondary": "var(--brutal-secondary, #4ECDC4)",
            "brutal-accent": "var(--brutal-accent, #FFE66D)",
            "brutal-destructive": "var(--brutal-destructive, #EF476F)",
            "brutal-success": "var(--brutal-success, #7FB069)",
            "brutal-muted": "var(--brutal-muted, #f3f4f6)",
            "brutal-ring": "var(--brutal-ring, #000000)",
            "brutal-info": "var(--brutal-info, #4A90D9)",
            "brutal-muted-foreground": "var(--brutal-muted-foreground, #4B5563)",
            "brutal-overlay": "var(--brutal-overlay, rgba(0, 0, 0, 0.5))",
            "brutal-placeholder": "var(--brutal-placeholder, #9CA3AF)"
          },
          "boxShadow": {
            "brutal": "var(--brutal-shadow-offset-x, 4px) var(--brutal-shadow-offset-y, 4px) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-sm": "calc(var(--brutal-shadow-offset-x, 4px) / 2) calc(var(--brutal-shadow-offset-y, 4px) / 2) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-lg": "calc(var(--brutal-shadow-offset-x, 4px) * 1.5) calc(var(--brutal-shadow-offset-y, 4px) * 1.5) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-xl": "calc(var(--brutal-shadow-offset-x, 4px) * 2) calc(var(--brutal-shadow-offset-y, 4px) * 2) 0px 0px var(--brutal-shadow-color, #000000)"
          }
        }
      }
    }
  },
  "cssVars": {
