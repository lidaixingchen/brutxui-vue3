{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "submit-button",
  "type": "registry:ui",
  "title": "Submit Button",
  "description": "A highly customizable neo-brutalist Submit Button component built with Brutx design tokens for Vue 3.",
  "dependencies": [],
  "registryDependencies": [
    "button"
  ],
  "files": [
    {
      "path": "components/ui/submit-button/SubmitButton.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed } from 'vue'\nimport { Loader2 } from 'lucide-vue-next'\nimport { cn } from '@/lib/utils'\nimport { buttonVariants } from '@/components/ui/button/button-variants'\nimport { type VariantProps } from 'class-variance-authority'\n\ntype ButtonVariantProps = VariantProps<typeof buttonVariants>\n\ninterface SubmitButtonProps {\n    variant?: NonNullable<ButtonVariantProps['variant']>\n    size?: NonNullable<ButtonVariantProps['size']>\n    pendingText?: string\n    loading?: boolean\n    disabled?: boolean\n    class?: string\n}\n\nconst props = withDefaults(defineProps<SubmitButtonProps>(), {\n    variant: 'default',\n    size: 'default',\n    pendingText: 'Submitting...',\n    loading: false,\n    disabled: false,\n})\n\nconst isDisabled = computed(() => props.disabled || props.loading)\n\nconst classes = computed(() =>\n    cn(buttonVariants({ variant: props.variant, size: props.size }), props.class)\n)\n</script>\n\n<template>\n    <button type=\"submit\" :class=\"classes\" :disabled=\"isDisabled\">\n        <Loader2 v-if=\"loading\" class=\"h-4 w-4 animate-spin\" />\n        <template v-if=\"loading && pendingText\">{{ pendingText }}</template>\n        <slot v-else />\n    </button>\n</template>\n",
      "type": "registry:ui"
    }
  ],
  "tailwind": {
    "config": {
      "theme": {
        "extend": {
          "borderWidth": {
            "3": "var(--brutal-border-width, 3px)"
          },
          "borderColor": {
            "brutal": "var(--brutal-border-color, #000000)"
          },
          "borderRadius": {
            "brutal": "var(--brutal-radius, 0px)"
          },
          "colors": {
            "brutal-bg": "var(--brutal-bg, #ffffff)",
            "brutal-fg": "var(--brutal-fg, #000000)",
            "brutal-primary": "var(--brutal-primary, #FF6B6B)",
            "brutal-secondary": "var(--brutal-secondary, #4ECDC4)",
            "brutal-accent": "var(--brutal-accent, #FFE66D)",
            "brutal-destructive": "var(--brutal-destructive, #EF476F)",
            "brutal-success": "var(--brutal-success, #7FB069)",
            "brutal-muted": "var(--brutal-muted, #f3f4f6)",
            "brutal-ring": "var(--brutal-ring, #000000)"
          },
          "boxShadow": {
            "brutal": "var(--brutal-shadow-offset-x, 4px) var(--brutal-shadow-offset-y, 4px) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-sm": "calc(var(--brutal-shadow-offset-x, 4px) / 2) calc(var(--brutal-shadow-offset-y, 4px) / 2) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-lg": "calc(var(--brutal-shadow-offset-x, 4px) * 1.5) calc(var(--brutal-shadow-offset-y, 4px) * 1.5) 0px 0px var(--brutal-shadow-color, #000000)",
            "brutal-xl": "calc(var(--brutal-shadow-offset-x, 4px) * 2) calc(var(--brutal-shadow-offset-y, 4px) * 2) 0px 0px var(--brutal-shadow-color, #000000)"
          }
        }
      }
    }
  },
  "cssVars": {
    "light": {
