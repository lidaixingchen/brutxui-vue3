{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "kanban",
  "type": "registry:ui",
  "title": "Kanban",
  "description": "Drag-and-drop kanban board with columns and cards.",
  "category": "utility",
