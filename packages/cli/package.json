{
    "name": "brutx",
    "version": "0.3.0",
    "description": "CLI for adding Brutalist UI components to your project",
    "bin": {
        "brutx": "dist/index.js"
    },
    "main": "./dist/index.js",
    "type": "module",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "start": "node dist/index.js",
        "test": "vitest run"
    },
    "dependencies": {
        "brutx-shared": "workspace:*",
        "chalk": "^5.3.0",
        "commander": "^12.0.0",
        "fs-extra": "^11.2.0",
        "inquirer": "^9.2.12",
        "ora": "^8.0.1"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^20.17.15",
        "tsup": "^8.0.1",
        "typescript": "^5.7.2",
        "vitest": "^1.3.1"
    },
    "keywords": [
        "brutx",
        "cli",
        "neo-brutalism",
        "react",
        "components"
    ],
    "author": "dev-snake",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/dev-snake/brutxui"
    },
    "homepage": "https://brutxui.site"
}
