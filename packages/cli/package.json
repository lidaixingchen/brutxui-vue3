{
    "name": "brutx-vue",
    "version": "0.7.0",
    "description": "CLI for adding Neo-Brutalist Vue 3 UI components to your project",
    "bin": {
        "brutx-vue": "dist/index.js"
    },
    "main": "./dist/index.js",
    "type": "module",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "prepack": "tsup",
        "dev": "tsup --watch",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit",
        "test": "vitest run --exclude \"tests/integration/**\"",
        "test:integration": "vitest run tests/integration"
    },
    "dependencies": {
        "@inquirer/prompts": "^8.5.2",
        "chalk": "^5.3.0",
        "commander": "^15.0.0",
        "diff": "^7.0.0",
        "es-module-lexer": "^2.2.0",
        "fs-extra": "^11.3.5",
        "jsonc-parser": "^3.3.1",
        "ora": "^9.4.0"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^25.9.1",
        "@vitest/coverage-v8": "^4.1.8",
        "brutx-shared-vue": "workspace:*",
        "tsup": "^8.0.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    },
    "keywords": [
        "brutx-vue",
        "cli",
        "neo-brutalism",
        "vue",
        "vue3",
        "components",
        "tailwindcss"
    ],
    "author": "lidaixingchen",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/lidaixingchen/brutxui-vue3"
    },
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=9.0.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "homepage": "https://lidaixingchen.github.io/brutxui-vue3/"
}
