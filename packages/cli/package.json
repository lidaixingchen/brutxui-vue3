{
    "name": "brutx-vue",
    "version": "0.3.4",
    "description": "CLI for adding Neo-Brutalist Vue 3 UI components to your project",
    "bin": {
        "brutx-vue": "dist/index.js"
    },
    "main": "./dist/index.js",
    "type": "module",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "start": "node dist/index.js",
        "test": "vitest run"
    },
    "dependencies": {
        "@inquirer/prompts": "^8.5.2",
        "chalk": "^5.3.0",
        "commander": "^13.1.0",
        "fs-extra": "^11.3.5",
        "ora": "^9.4.0"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^22.19.19",
        "@vitest/coverage-v8": "4",
        "tsup": "^8.0.1",
        "typescript": "^5.7.2",
        "vitest": "^4.1.8"
    },
    "keywords": [
        "brutx-vue",
        "cli",
        "neo-brutalism",
        "vue",
        "vue3",
        "components",
        "tailwindcss"
    ],
    "author": "lidaixingchen",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/lidaixingchen/brutxui-vue3"
    },
    "homepage": "https://lidaixingchen.github.io/brutxui-vue3/"
}
