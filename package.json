{
    "name": "brutx-monorepo",
    "version": "1.0.0",
    "private": true,
    "description": "Neo-Brutalism UI Library Monorepo (Vue 3)",
    "scripts": {
        "dev": "pnpm --filter docs dev",
        "build": "pnpm --filter brutx-ui-vue build",
        "build:ui": "pnpm --filter brutx-ui-vue build",
        "build:docs": "pnpm --filter docs build",
        "lint": "pnpm -r lint",
        "clean": "pnpm -r clean",
        "typecheck": "pnpm -r typecheck",
        "test": "pnpm --filter brutx-ui-vue test",
        "test:watch": "pnpm --filter brutx-ui-vue test:watch",
        "test:coverage": "pnpm --filter brutx-ui-vue test:coverage",
        "release:check": "node scripts/release/check-release.mjs",
        "changelog": "node scripts/release/generate-changelog.mjs",
        "changelog:dry": "node scripts/release/generate-changelog.mjs --dry-run",
        "changelog:full": "node scripts/release/generate-changelog.mjs --full-history",
        "changelog:ui": "node scripts/release/generate-changelog.mjs --scope ui",
        "changelog:cli": "node scripts/release/generate-changelog.mjs --scope cli",
        "generate:component": "tsx scripts/generate.ts component",
        "generate:composable": "tsx scripts/generate.ts composable",
        "generate:page": "tsx scripts/generate.ts page"
    },
    "engines": {
        "node": ">=22.5.0",
        "pnpm": ">=11.0.0"
    },
    "packageManager": "pnpm@11.10.0"
}
