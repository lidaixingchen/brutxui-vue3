{
    "name": "brutx-monorepo",
    "version": "1.0.0",
    "private": true,
    "description": "Neo-Brutalism UI Library Monorepo (Vue 3)",
    "scripts": {
        "dev": "pnpm --filter docs dev",
        "build": "turbo run build",
        "build:docs": "turbo run build --filter=docs",
        "lint": "turbo run lint",
        "clean": "turbo run clean",
        "typecheck": "turbo run typecheck",
        "test": "turbo run test",
        "test:ssr": "turbo run test:ssr",
        "test:watch": "pnpm --filter brutx-ui-vue test:watch",
        "test:coverage": "pnpm --filter brutx-ui-vue test:coverage",
        "bench": "turbo run bench",
        "changeset": "changeset",
        "version-packages": "changeset version",
        "release": "turbo run build test typecheck lint && changeset publish",
        "check:i18n": "node scripts/check-i18n.mjs --report",
        "check:i18n:strict": "node scripts/check-i18n.mjs",
        "generate:component": "tsx scripts/generate.ts component",
        "generate:composable": "tsx scripts/generate.ts composable",
        "generate:page": "tsx scripts/generate.ts page"
    },
    "engines": {
        "node": ">=22.5.0",
        "pnpm": ">=11.0.0"
    },
    "packageManager": "pnpm@11.10.0",
    "devDependencies": {
        "@changesets/cli": "^2.31.1",
        "turbo": "^2.10.5"
    }
}
