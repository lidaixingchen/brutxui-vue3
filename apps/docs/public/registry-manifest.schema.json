{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://lidaixingchen.github.io/brutxui-vue3/registry-manifest.schema.json",
    "title": "BrutxUI Vue Registry Build Manifest",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "$schema",
        "name",
        "schemaVersion",
        "registryVersion",
        "buildTimestamp",
        "gitCommit",
        "itemCount",
        "items"
    ],
    "properties": {
        "$schema": {
            "const": "https://lidaixingchen.github.io/brutxui-vue3/registry-manifest.schema.json"
        },
        "name": {
            "type": "string",
            "minLength": 1
        },
        "schemaVersion": {
            "type": "integer",
            "minimum": 1
        },
        "registryVersion": {
            "type": "string",
            "minLength": 1
        },
        "buildTimestamp": {
            "type": [
                "string",
                "null"
            ],
            "format": "date-time"
        },
        "gitCommit": {
            "type": [
                "string",
                "null"
            ],
            "minLength": 1
        },
        "itemCount": {
            "type": "integer",
            "minimum": 0
        },
        "items": {
            "type": "object",
            "additionalProperties": {
                "$ref": "#/$defs/manifestItem"
            }
        }
    },
    "$defs": {
        "manifestItem": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "integrity",
                "fileCount",
                "dependencies",
                "registryDependencies"
            ],
            "properties": {
                "integrity": {
                    "type": "string",
                    "pattern": "^sha256-[a-f0-9]+$"
                },
                "fileCount": {
                    "type": "integer",
                    "minimum": 0
                },
                "dependencies": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    },
                    "uniqueItems": true
                },
                "registryDependencies": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    },
                    "uniqueItems": true
                },
                "category": {
                    "enum": [
                        "action",
                        "data-display",
                        "feedback",
                        "form",
                        "layout",
                        "marketing",
                        "media",
                        "navigation",
                        "overlay",
                        "page",
                        "utility",
                        "visual-effect"
                    ]
                },
                "examples": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    },
                    "uniqueItems": true
                },
                "status": {
                    "enum": [
                        "stable",
                        "legacy",
                        "deprecated"
                    ]
                },
                "replacement": {
                    "type": "string",
                    "minLength": 1
                }
            }
        }
    }
}
