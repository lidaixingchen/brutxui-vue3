{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "noEmit": true,
        "paths": {
            "@/*": ["./.vitepress/*"]
        }
    },
    "include": ["env.d.ts", ".vitepress/**/*.ts", ".vitepress/**/*.vue"],
    "exclude": ["node_modules"]
}
