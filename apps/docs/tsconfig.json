{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "noEmit": true,
        "paths": {
            "@/*": ["./.vitepress/*"]
        }
    },
    "include": [".vitepress/**/*.ts", ".vitepress/**/*.vue"],
    "exclude": ["node_modules"]
}
