{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "env": ["VERCEL"],
            "outputs": [
                "dist/**",
                ".vitepress/dist/**",
                "registry-manifest.json",
                "exports-manifest.json",
                "src/components/*/index.ts",
                "registry/**"
            ],
            "inputs": [
                "src/**",
                "scripts/**",
                "package.json",
                "tsconfig.json",
                "tsconfig.*.json",
                "vite.config.ts",
                "tailwind.config.*",
                "postcss.config.*"
            ]
        },
        "docs#build": {
            "dependsOn": ["^build"],
            "outputs": [
                ".vitepress/dist/**"
            ],
            "inputs": [
                "**/*.md",
                ".vitepress/config.ts",
                ".vitepress/theme/**/*",
                "public/**/*",
                "package.json",
                "tsconfig.json"
            ]
        },
        "test": {
            "dependsOn": ["build"],
            "inputs": [
                "src/**",
                "tests/**",
                "vitest.config.ts",
                "vitest.browser.config.ts",
                "vitest.ssr.config.ts",
                "registry/**"
            ]
        },
        "test:ssr": {
            "dependsOn": ["build"],
            "inputs": ["src/**", "vitest.ssr.config.ts"]
        },
        "typecheck": {
            "dependsOn": ["^build"],
            "inputs": ["src/**", "tsconfig.json", "tsconfig.*.json"]
        },
        "lint": {
            "inputs": ["src/**", "eslint.config.js", ".eslintrc.*"]
        },
        "validate": {
            "dependsOn": ["build"],
            "inputs": [
                "scripts/**",
                "registry/**",
                "../../packages/ui/src/components/**",
                "../../packages/ui/src/composables/**",
                "../../packages/ui/src/directives/**",
                "../../apps/docs/**/*.md",
                "../../packages/shared/src/**"
            ]
        },
        "bench": {
            "cache": false,
            "inputs": ["perf/**", "src/**"]
        },
        "clean": {
            "cache": false
        }
    }
}
